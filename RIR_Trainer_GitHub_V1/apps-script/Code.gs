  return { ok: true, insertedExercise, sessionState };
}


function saveWarmupBatch_(ss, payload, email) {
  const rows = Array.isArray(payload.rows) ? payload.rows : [];
  if (!rows.length) return { ok: true, inserted: 0, updated: 0, rows: [] };
  if (rows.length > 30) throw new Error('Demasiados ejercicios de calentamiento en un único envío.');
  const workoutId = requiredId_(payload.ID_Entrenamiento || rows[0].ID_Entrenamiento, 'ID_Entrenamiento');
  const sessionId = requiredId_(payload.ID_Sesion || rows[0].ID_Sesion, 'ID_Sesion');
  const dateKey = normalizeDateKey_(payload.Fecha || rows[0].Fecha);
  if (!/^\d{4}-\d{2}-\d{2}$/.test(dateKey) || isFutureDateKey_(dateKey)) {
    throw new Error('La fecha del calentamiento no es válida.');
  }
  const sessionExists = sheetToObjectsRaw_(ss, 'Sesiones').some(r => String(r.ID_Sesion) === sessionId);
  if (!sessionExists) throw new Error('La sesión del calentamiento no existe.');
  const validWarmups = new Set(sheetToObjectsRaw_(ss, 'Calentamientos').map(r => String(r.ID_Calentamiento)));
  const now = new Date();
  const sanitized = rows.map(row => {
    const warmupId = requiredId_(row.ID_Calentamiento, 'ID_Calentamiento');
    if (!validWarmups.has(warmupId)) throw new Error('Calentamiento no encontrado: ' + warmupId);
    return {
      ID_RegistroCalentamiento: cleanText_(row.ID_RegistroCalentamiento, 180) || ('WARM-' + workoutId + '-' + warmupId),
      ID_Entrenamiento: workoutId,
      Fecha: parseDateOrToday_(dateKey),
      ID_Sesion: sessionId,
      ID_Calentamiento: warmupId,
      Completado: toBoolean_(row.Completado),
      Timestamp: now,
      Usuario: email,
    };
  });
  const sheet = ensureSheet_(ss, 'RegistroCalentamientos', RIR_HEADERS.RegistroCalentamientos);
  ensureHeaders_(ss, 'RegistroCalentamientos', RIR_HEADERS.RegistroCalentamientos);
  let inserted = 0, updated = 0;
  const saved = sanitized.map(object => {
    const result = upsertObjectByColumns_(sheet, object, ['ID_Entrenamiento', 'ID_Calentamiento'], ['ID_RegistroCalentamiento']);
    if (result.action === 'inserted') inserted++; else updated++;
    return serializeObject_(result.object);
  });
  SpreadsheetApp.flush();
  return { ok: true, inserted, updated, rows: saved };
}

function saveSubstitution_(ss, payload, email) {
  const raw = payload.substitution || payload;
  const workoutId = requiredId_(raw.ID_Entrenamiento, 'ID_Entrenamiento');
  const sessionId = requiredId_(raw.ID_Sesion, 'ID_Sesion');
  const originalId = requiredId_(raw.ID_EjercicioOriginal, 'ID_EjercicioOriginal');
  const dateKey = normalizeDateKey_(raw.Fecha);
  if (!/^\d{4}-\d{2}-\d{2}$/.test(dateKey) || isFutureDateKey_(dateKey)) {
    throw new Error('La sustitución solo puede aplicarse a un entrenamiento actual o pasado.');
  }
  const original = getExercisePlan_(ss, originalId);
  if (!original || String(original.ID_Sesion) !== sessionId) throw new Error('El ejercicio original no pertenece a la sesión.');
  const alternativeId = cleanText_(raw.ID_EjercicioAlternativo, 120);
  const alternative = alternativeId ? getExercisePlan_(ss, alternativeId) : null;
  const alternativeName = cleanText_(raw.NombreAlternativo || (alternative && alternative.NombreEjercicio), 180);
  if (!alternativeName) throw new Error('Indica el ejercicio alternativo.');
  const object = {
    ID_Sustitucion: cleanText_(raw.ID_Sustitucion, 160) || ('SUS-' + Utilities.getUuid()),
    ID_Entrenamiento: workoutId,
    Fecha: parseDateOrToday_(dateKey),
    ID_Sesion: sessionId,
    ID_EjercicioOriginal: originalId,
    ID_EjercicioAlternativo: alternativeId,
    NombreAlternativo: alternativeName,
    GrupoMuscularAlternativo: cleanText_(raw.GrupoMuscularAlternativo || (alternative && alternative.GrupoMuscular) || original.GrupoMuscular, 80),
    Estado: 'activo',
    Timestamp: new Date(),
    Usuario: email,
  };
  const sheet = ensureSheet_(ss, 'SustitucionesSesion', RIR_HEADERS.SustitucionesSesion);
  ensureHeaders_(ss, 'SustitucionesSesion', RIR_HEADERS.SustitucionesSesion);
  const headers = getHeaders_(sheet);
  const rows = sheet.getLastRow() > 1 ? sheet.getRange(2, 1, sheet.getLastRow()-1, headers.length).getValues() : [];
  const idIndex = headers.indexOf('ID_Sustitucion');
  const workoutIndex = headers.indexOf('ID_Entrenamiento');
  const originalIndex = headers.indexOf('ID_EjercicioOriginal');
  let target = rows.findIndex(r => String(r[idIndex]) === object.ID_Sustitucion);
  if (target < 0) target = rows.findIndex(r => String(r[workoutIndex]) === workoutId && String(r[originalIndex]) === originalId);
  const values = headers.map(h => object[h] !== undefined ? object[h] : '');
  if (target >= 0) sheet.getRange(target+2, 1, 1, headers.length).setValues([values]);
  else sheet.getRange(sheet.getLastRow()+1, 1, 1, headers.length).setValues([values]);
  return { ok: true, substitution: serializeObject_(object), action: target >= 0 ? 'updated' : 'inserted' };
}

function deleteSubstitution_(ss, payload, email) {
  const id = requiredId_(payload.ID_Sustitucion, 'ID_Sustitucion');
  const sheet = ensureSheet_(ss, 'SustitucionesSesion', RIR_HEADERS.SustitucionesSesion);
  const headers = getHeaders_(sheet);
  const idCol = headers.indexOf('ID_Sustitucion') + 1;
  const stateCol = headers.indexOf('Estado') + 1;
  const tsCol = headers.indexOf('Timestamp') + 1;
  const userCol = headers.indexOf('Usuario') + 1;
  const ids = sheet.getLastRow() > 1 ? sheet.getRange(2, idCol, sheet.getLastRow()-1, 1).getValues().flat() : [];
  const idx = ids.findIndex(v => String(v) === id);
  if (idx < 0) return { ok: true, deleted: false };
  const row = idx + 2;
  sheet.getRange(row, stateCol).setValue('eliminado');
  if (tsCol > 0) sheet.getRange(row, tsCol).setValue(new Date());
  if (userCol > 0) sheet.getRange(row, userCol).setValue(email);
  return { ok: true, deleted: true, ID_Sustitucion: id };
}

function saveCalendarActivity_(ss, payload, email) {
  const raw = payload.activity || payload;
  const dateKey = normalizeDateKey_(raw.Fecha || raw.date || raw.key || (raw.row && raw.row.Fecha));
  if (!/^\d{4}-\d{2}-\d{2}$/.test(dateKey)) throw new Error('Fecha de calendario no válida.');

  let category = cleanText_(raw.Categoria || raw.category, 30).toLowerCase();
  let type = cleanText_(raw.Tipo || raw.activityType || raw.tipo || (raw.row && raw.row.ComentarioGeneral), 80);
  const legacy = type.toLowerCase();
  let duration = toOptionalNumber_(raw.DuracionMin);
  let distance = toOptionalNumber_(raw.DistanciaKm);
  let steps = toOptionalNumber_(raw.Pasos);
  let elevation = toOptionalNumber_(raw.DesnivelM);
  const environment = cleanText_(raw.Entorno, 80);
  const pace = cleanText_(raw.Ritmo, 40);
  const intensity = cleanText_(raw.Intensidad, 40);
  const wetsuit = toBoolean_(raw.Neopreno);
  if (!category) {
    if (/^fuerza-d[123]$/.test(legacy)) { category = 'fuerza'; type = legacy.replace('fuerza-', '').toUpperCase(); }
    else if (legacy === 'pasos') { category = 'cardio'; type = 'Caminar'; steps = steps || 10000; }
    else if (legacy === 'cardio') { category = 'cardio'; type = 'Otro'; }
    else if (legacy === 'descanso') { category = 'descanso'; type = 'Descanso'; }
  }
  if (!['fuerza','cardio','descanso'].includes(category)) throw new Error('Categoría de actividad no permitida.');
  if (category === 'fuerza' && !['D1','D2','D3'].includes(type.toUpperCase())) throw new Error('Sesión de fuerza no válida.');
  if (category === 'cardio' && !['caminar','bici','nadar','correr','otro'].includes(type.toLowerCase())) throw new Error('Tipo de cardio no permitido.');
  if (category === 'descanso') type = 'Descanso';

  const status = cleanText_(raw.Estado || raw.status || 'hecho', 20).toLowerCase();
  if (!['hecho','planificado'].includes(status)) throw new Error('Estado de actividad no válido.');
  if (isFutureDateKey_(dateKey) && status === 'hecho') throw new Error('Una actividad futura solo puede guardarse como planificada.');

  const sessionId = cleanText_(raw.ID_Sesion, 120);
  if (category === 'fuerza' && sessionId) {
    const exists = sheetToObjectsRaw_(ss, 'Sesiones').some(row => String(row.ID_Sesion) === sessionId);
    if (!exists) throw new Error('La sesión indicada no existe.');
  }

  const sheet = ensureSheet_(ss, 'CalendarioActividades', RIR_HEADERS.CalendarioActividades);
  ensureHeaders_(ss, 'CalendarioActividades', RIR_HEADERS.CalendarioActividades);
  const headers = getHeaders_(sheet);
  let activityId = cleanText_(raw.ID_Actividad, 120) || ('CAL-' + Utilities.getUuid());
  const rows = sheet.getLastRow() > 1 ? sheet.getRange(2, 1, sheet.getLastRow()-1, headers.length).getValues() : [];
  const idIndex = headers.indexOf('ID_Actividad');
  const dateIndex = headers.indexOf('Fecha');
  const catIndex = headers.indexOf('Categoria');
  const sessionIndex = headers.indexOf('ID_Sesion');
  const typeIndex = headers.indexOf('Tipo');
  const stateIndex = headers.indexOf('Estado');
  const workoutIndex = headers.indexOf('ID_Entrenamiento');
  let targetIndex = rows.findIndex(row => String(row[idIndex]) === activityId);

  // Regla de producto: como máximo una sesión de fuerza por fecha.
  // Una planificación puede sustituirse por otra, pero una sesión iniciada o
  // realizada bloquea cualquier segunda sesión de fuerza ese mismo día.
  if (category === 'fuerza') {
    const sameDayStrength = rows
      .map((row, index) => ({ row, index }))
      .filter(item => normalizeDateKey_(item.row[dateIndex]) === dateKey &&
        String(item.row[catIndex] || '').toLowerCase() === 'fuerza' &&
        String(item.row[stateIndex] || '').toLowerCase() !== 'eliminado');

    const sameLogical = sameDayStrength.find(item =>
      String(item.row[idIndex]) === activityId ||
      (sessionId && String(item.row[sessionIndex]) === sessionId) ||
      String(item.row[typeIndex] || '').toUpperCase() === type.toUpperCase()
    );
    if (sameLogical) {
      targetIndex = sameLogical.index;
      activityId = String(sameLogical.row[idIndex] || activityId);
    } else if (sameDayStrength.length) {
      const existing = sameDayStrength[0];
      const existingStatus = String(existing.row[stateIndex] || '').toLowerCase();
      const existingWorkout = String(existing.row[workoutIndex] || '');
      if (existingStatus === 'planificado' && status === 'planificado' && !existingWorkout) {
        // Cambiar la planificación del día reutilizando la misma fila.
        targetIndex = existing.index;
        activityId = String(existing.row[idIndex] || activityId);
      } else {
        throw new Error('Ya hay una sesión de fuerza registrada para ese día. Puedes añadir cardio, paseo o pasos.');
      }
    }
  }

  if (category === 'descanso') {
    const hasStrength = rows.some(row => normalizeDateKey_(row[dateIndex]) === dateKey &&
      String(row[catIndex] || '').toLowerCase() === 'fuerza' &&
      String(row[stateIndex] || '').toLowerCase() !== 'eliminado');
    if (hasStrength) throw new Error('Ese día ya tiene una sesión de fuerza. Puedes añadir cardio o pasos, pero no marcarlo como descanso.');
  }
  const object = {
    ID_Actividad:activityId, Fecha:parseDateOrToday_(dateKey), Categoria:category,
    Tipo:category==='fuerza'?type.toUpperCase():type, Detalle:cleanText_(raw.Detalle, RIR_CONFIG.MAX_COMMENT_LENGTH),
    DuracionMin:duration===null?'':boundedNumber_(duration,0,1440,'DuracionMin'),
    DistanciaKm:distance===null?'':boundedNumber_(distance,0,1000,'DistanciaKm'),
    Pasos:steps===null?'':positiveInt_(steps,0,200000,'Pasos'),
    DesnivelM:elevation===null?'':boundedNumber_(elevation,0,20000,'DesnivelM'),
    Entorno:environment, Ritmo:pace, Intensidad:intensity, Neopreno:wetsuit,
    Estado:status,
    ID_Sesion:sessionId, ID_Entrenamiento:cleanText_(raw.ID_Entrenamiento,120), Timestamp:new Date(), Usuario:email
  };
  const values=headers.map(header=>object[header]!==undefined?object[header]:'');
  if(targetIndex>=0) sheet.getRange(targetIndex+2,1,1,headers.length).setValues([values]);
  else sheet.getRange(sheet.getLastRow()+1,1,1,headers.length).setValues([values]);
  return {ok:true, action:targetIndex>=0?'updated':'inserted', activity:serializeObject_(object)};
}

function deleteCalendarActivity_(ss, payload, email) {
  const id = requiredId_(payload.ID_Actividad, 'ID_Actividad');
  const sheet = ensureSheet_(ss, 'CalendarioActividades', RIR_HEADERS.CalendarioActividades);
  const headers=getHeaders_(sheet), idCol=headers.indexOf('ID_Actividad')+1, stateCol=headers.indexOf('Estado')+1, userCol=headers.indexOf('Usuario')+1, tsCol=headers.indexOf('Timestamp')+1;
  if(idCol<=0||stateCol<=0) throw new Error('Estructura de calendario incompleta.');
  const ids=sheet.getLastRow()>1?sheet.getRange(2,idCol,sheet.getLastRow()-1,1).getValues().flat():[];
  const idx=ids.findIndex(v=>String(v)===id); if(idx<0)return {ok:true,deleted:false};
  const row=idx+2; sheet.getRange(row,stateCol).setValue('eliminado'); if(userCol>0)sheet.getRange(row,userCol).setValue(email); if(tsCol>0)sheet.getRange(row,tsCol).setValue(new Date());
  return {ok:true,deleted:true,ID_Actividad:id};
}

function saveWorkoutSummary_(ss, payload, email) {
  const workoutId = requiredId_(payload.ID_Entrenamiento, 'ID_Entrenamiento');
  const sessionId = requiredId_(payload.ID_Sesion, 'ID_Sesion');
  const dateKey = normalizeDateKey_(payload.Fecha);
  if (!/^\d{4}-\d{2}-\d{2}$/.test(dateKey)) throw new Error('Fecha de entrenamiento no válida.');
  if (isFutureDateKey_(dateKey)) throw new Error('No se puede finalizar un entrenamiento futuro.');

  const session = sheetToObjectsRaw_(ss, 'Sesiones').find(r => String(r.ID_Sesion) === sessionId);
  if (!session) throw new Error('La sesión no existe.');
  const exercises = sheetToObjectsRaw_(ss, 'EjerciciosPlan').filter(r => String(r.ID_Sesion) === sessionId);
  const exerciseIds = new Set(exercises.map(r => String(r.ID_EjercicioPlan)));
  const planById = new Map(sheetToObjectsRaw_(ss, 'EjerciciosPlan').map(r => [String(r.ID_EjercicioPlan), r]));

  let series = sheetToObjectsRaw_(ss, 'RegistroSeries').filter(r => String(r.ID_Entrenamiento) === workoutId && toBoolean_(r.Completada));
  if (!series.length) series = sheetToObjectsRaw_(ss, 'RegistroSeries').filter(r => exerciseIds.has(String(r.ID_EjercicioPlan)) && normalizeDateKey_(r.Fecha) === dateKey && toBoolean_(r.Completada));
  if (!series.length) throw new Error('No hay series guardadas para este entrenamiento.');

  let exerciseRows = sheetToObjectsRaw_(ss, 'RegistroEjercicios').filter(r => String(r.ID_Entrenamiento) === workoutId);
  if (!exerciseRows.length) exerciseRows = sheetToObjectsRaw_(ss, 'RegistroEjercicios').filter(r => exerciseIds.has(String(r.ID_EjercicioPlan)) && normalizeDateKey_(r.Fecha) === dateKey);
  const started = new Set(series.map(r => String(r.ID_EjercicioPlan)));
  const completed = new Set(exerciseRows.filter(r => toBoolean_(r.EjercicioCompletado)).map(r => String(r.ID_EjercicioPlan)));
  const volume = series.reduce((sum,r) => sum + (normalizeNumber_(r.Peso) || 0) * (normalizeNumber_(r.RepsRealizadas) || 0), 0);
  const reps = series.reduce((sum,r) => sum + (Number(r.RepsRealizadas) || 0), 0);
  const rirs = series.map(r => toOptionalNumber_(r.RIRReal)).filter(v => v !== null);
  const workoutSheetExisting = ensureSheet_(ss, 'RegistroEntrenamientos', RIR_HEADERS.RegistroEntrenamientos);
  ensureHeaders_(ss, 'RegistroEntrenamientos', RIR_HEADERS.RegistroEntrenamientos);
  const existingWorkout = findObjectByColumns_(workoutSheetExisting, { ID_Entrenamiento: workoutId }) || {};
  const firstSeriesDate = series.map(r => parseDate_(r.Timestamp)).filter(Boolean).sort((a,b)=>a-b)[0] || new Date();
  const startTime = parseTimestampOrNow_(payload.HoraInicio || existingWorkout.HoraInicio, firstSeriesDate);
  const endTime = new Date();
  const duration = Math.max(1, Math.min(1440, Math.round((endTime - startTime) / 60000)));
  const omitted = exercises.filter(e => !started.has(String(e.ID_EjercicioPlan))).map(e => String(e.NombreEjercicio || e.ID_EjercicioPlan));
  const status = completed.size >= exercises.length ? 'Completa' : 'Parcial';
  const warmupRows = sheetToObjectsRaw_(ss, 'RegistroCalentamientos').filter(r => String(r.ID_Entrenamiento) === workoutId && toBoolean_(r.Completado));
  const sessionCode = (sessionId.match(/-(D[123])$/) || [])[1] || 'D1';
  const warmupPlan = sheetToObjectsRaw_(ss, 'Calentamientos').filter(r => String(r.SesionTipo).toUpperCase() === sessionCode && String(r.Activo || 'TRUE').toUpperCase() !== 'FALSE');

  const warnings = [];
  let progress = { improvements: [], records: [] };
  let muscles = { text: '', items: [] };
  let decisions = [];
  try { progress = analyseWorkoutProgressV6_(ss, series, workoutId, planById); }
  catch (err) { warnings.push('No se pudo calcular la progresión: ' + err.message); }
  try { muscles = calculateWorkoutMuscles_(ss, series, planById); }
  catch (err) { warnings.push('No se pudo calcular el volumen muscular: ' + err.message); }
  try { decisions = buildNextSessionDecisions_(ss, series, workoutId, planById); }
  catch (err) { warnings.push('No se pudieron calcular las decisiones de la próxima sesión: ' + err.message); }

  const restSecondsRaw = toOptionalNumber_(payload.TiempoDescansoSeg);
  const restSeconds = Math.max(0, Math.min(duration * 60, Math.round(restSecondsRaw === null ? (normalizeNumber_(existingWorkout.TiempoDescansoSeg) || 0) : restSecondsRaw)));
  const activeMinutes = Math.max(0, Math.round((duration - restSeconds / 60) * 10) / 10);
  const energy = toOptionalNumber_(payload.Energia);
  const difficulty = toOptionalNumber_(payload.Dificultad);
  const discomfort = toOptionalNumber_(payload.Molestias);
  const object = {
    ID_Entrenamiento: workoutId, ID_Sesion: sessionId, Fecha: parseDateOrToday_(dateKey),
    HoraInicio: startTime, HoraFin: endTime, DuracionMin: duration,
    EjerciciosRealizados: started.size, EjerciciosCompletados: completed.size, EjerciciosPlanificados: exercises.length,
    SeriesRealizadas: series.length, RepeticionesTotales: reps, VolumenKg: Math.round(volume),
    RIRMedio: rirs.length ? Math.round((rirs.reduce((a,b) => a+b,0) / rirs.length) * 10) / 10 : '',
    Estado: status, EjerciciosOmitidos: omitted.join(' | '),
    Energia: boundedNumber_(energy === null ? 3 : energy, 1, 5, 'Energia'),
    Dificultad: boundedNumber_(difficulty === null ? 3 : difficulty, 1, 5, 'Dificultad'),
    Molestias: boundedNumber_(discomfort === null ? 0 : discomfort, 0, 3, 'Molestias'),
    ComentarioFinal: cleanText_(payload.ComentarioFinal, RIR_CONFIG.MAX_COMMENT_LENGTH),
    CalentamientosRealizados: warmupRows.length,
    CalentamientosPlanificados: warmupPlan.length,
    MusculosTrabajados: muscles.text || '',
    Mejoras: (progress.improvements || []).join(' | '),
    Records: (progress.records || []).join(' | '),
    DecisionesProximaSesion: decisions.join(' | '),
    TiempoDescansoSeg: restSeconds,
    TiempoActivoMin: activeMinutes,
    FechaModificacion: new Date(),
    Usuario: email,
  };

  const sheet = ensureSheet_(ss, 'RegistroEntrenamientos', RIR_HEADERS.RegistroEntrenamientos);
  ensureHeaders_(ss, 'RegistroEntrenamientos', RIR_HEADERS.RegistroEntrenamientos);
  const headers = getHeaders_(sheet), idCol = headers.indexOf('ID_Entrenamiento') + 1;
  const ids = sheet.getLastRow() > 1 ? sheet.getRange(2, idCol, sheet.getLastRow()-1, 1).getValues().flat() : [];
  const idx = ids.findIndex(v => String(v) === workoutId);
  const values = headers.map(h => object[h] !== undefined ? object[h] : '');
  if (idx >= 0) sheet.getRange(idx+2,1,1,headers.length).setValues([values]);
  else sheet.getRange(sheet.getLastRow()+1,1,1,headers.length).setValues([values]);
  SpreadsheetApp.flush();

  try {
    saveCalendarActivity_(ss, { activity: {
      ID_Actividad: 'WORKOUT-' + workoutId, Fecha: dateKey, Categoria: 'fuerza', Tipo: sessionCode,
      Estado: 'hecho', ID_Sesion: sessionId, ID_Entrenamiento: workoutId,
      Detalle: `${started.size}/${exercises.length} ejercicios · ${series.length} series`
    }}, email);
  } catch (err) { warnings.push('Resumen guardado, pero el calendario no se actualizó: ' + err.message); }
  try { setSessionFinalState_(ss, sessionId, status, dateKey); }
  catch (err) { warnings.push('Resumen guardado, pero no se actualizó el estado de la sesión: ' + err.message); }

  return { ok: true, warnings, summary: { ...serializeObject_(object), Omitidos: omitted, Musculos: muscles.items || [], MejorasLista: progress.improvements || [], RecordsLista: progress.records || [], DecisionesLista: decisions } };
}




/**
 * Activa la escalera de cargas como progresión por defecto.
 * Conserva únicamente los ejercicios configurados explícitamente como Manual.
 */
function activarEscaleraCargasV61() {
  assertAuthorized_();
  return setLadderProgressionV61_(getSpreadsheet_());
}

function setLadderProgressionV61_(ss) {
  const sheet = ss.getSheetByName('EjerciciosPlan');
  if (!sheet || sheet.getLastRow() < 2) return { updated: 0, manual: 0 };
  ensureHeaders_(ss, 'EjerciciosPlan', RIR_EXERCISE_EXTRA_HEADERS);
  const headers = getHeaders_(sheet);
  const col = headers.indexOf('TipoProgresion') + 1;
  if (col <= 0) return { updated: 0, manual: 0 };
  const range = sheet.getRange(2, col, sheet.getLastRow() - 1, 1);
  const values = range.getValues();
  let updated = 0, manual = 0;
  values.forEach(row => {
    const raw = normalizeExerciseName_(row[0] || '');
    if (raw.indexOf('manual') >= 0) { manual++; return; }
    if (String(row[0] || '').trim() !== 'Escalera') {
      row[0] = 'Escalera';
      updated++;
    }
  });
  if (updated) range.setValues(values);
  return { updated, manual };
}

function parseRangeServer_(value) {
  const matches = String(value || '').replace(',', '.').match(/\d+(?:\.\d+)?/g) || [];
  const nums = matches.map(Number).filter(Number.isFinite);
  return nums.length ? { min: Math.min.apply(null, nums), max: Math.max.apply(null, nums) } : { min: 0, max: 0 };
}

function progressionIncrementServer_(ss, plan) {
  const custom = normalizeNumber_(plan.IncrementoCarga);
  if (Number.isFinite(custom) && custom > 0) return custom;
  const configRows = sheetToObjectsRaw_(ss, 'Configuracion');
  const config = configRows[0] || {};
  const category = String(plan.CategoriaProgresion || '').toLowerCase();
  if (category.indexOf('inferior') >= 0) return normalizeNumber_(config.IncrementoTrenInferior) || 5;
  if (category.indexOf('superior') >= 0) return normalizeNumber_(config.IncrementoTrenSuperior) || 2.5;
  return normalizeNumber_(config.IncrementoAccesorios) || 1;
}

function progressionTypeServer_(plan) {
  const raw = normalizeExerciseName_(plan.TipoProgresion || 'escalera');
  return raw.indexOf('manual') >= 0 ? 'manual' : 'escalera';
}

function groupByWorkout_(rows) {
  const groups = new Map();
  rows.forEach(r => {
    const key = String(r.ID_Entrenamiento || normalizeDateKey_(r.Fecha) || r.Timestamp || 'sin-id');
    if (!groups.has(key)) groups.set(key, []);
    groups.get(key).push(r);
  });
  return Array.from(groups.values()).sort((a,b) => latestSeriesTime_(b) - latestSeriesTime_(a));
}

function exerciseStats_(rows) {
  const valid = (rows || []).filter(r => toBoolean_(r.Completada));
  const sets = valid.map(r => ({
    weight: Math.max(0, normalizeNumber_(r.Peso) || 0),
    reps: Math.max(0, Number(r.RepsRealizadas) || 0),
    rir: toOptionalNumber_(r.RIRReal),
  }));
  const bestSet = sets.slice().sort((a,b) => {
    const ae = a.weight * (1 + Math.min(a.reps, 15) / 30);
    const be = b.weight * (1 + Math.min(b.reps, 15) / 30);
    return be - ae;
  })[0] || { weight:0, reps:0, rir:null };
  return {
    sets,
    maxLoad: Math.max(0, ...sets.map(s => s.weight)),
    totalReps: sets.reduce((s,x) => s + x.reps, 0),
    volume: sets.reduce((s,x) => s + x.weight * x.reps, 0),
    bestSet,
    e1rm: bestSet.weight > 0 ? bestSet.weight * (1 + Math.min(bestSet.reps, 15) / 30) : 0,
  };
}

function analyseWorkoutProgressV6_(ss, currentSeries, workoutId, planById) {
  const allPrevious = sheetToObjectsRaw_(ss, 'RegistroSeries')
    .filter(r => String(r.ID_Entrenamiento) !== workoutId && toBoolean_(r.Completada));
  const currentGroups = groupSeriesByActualExercise_(currentSeries, planById);
  const previousGroups = groupSeriesByActualExercise_(allPrevious, planById);
  const improvements = [];
  const records = [];

  currentGroups.forEach((rows, key) => {
    const name = actualExerciseName_(rows[0], planById);
    const current = exerciseStats_(rows);
    const previousRows = previousGroups.get(key) || [];
    if (!previousRows.length) return;
    const previousWorkouts = groupByWorkout_(previousRows);
    const latest = exerciseStats_(previousWorkouts[0] || []);
    const previousAll = exerciseStats_(previousRows);
    const previousMaxWorkoutVolume = Math.max(0, ...previousWorkouts.map(g => exerciseStats_(g).volume));
    const previousSameLoadReps = Math.max(0, ...previousRows
      .filter(r => Math.abs((normalizeNumber_(r.Peso) || 0) - current.maxLoad) < 0.001)
      .map(r => Number(r.RepsRealizadas) || 0));
    const currentSameLoadReps = Math.max(0, ...current.sets
      .filter(s => Math.abs(s.weight - current.maxLoad) < 0.001)
      .map(s => s.reps));

    if (current.maxLoad > previousAll.maxLoad + 0.001) {
      records.push(`${name} · mayor carga: ${roundOne_(current.maxLoad)} kg`);
    }
    if (current.e1rm > previousAll.e1rm * 1.005 && current.bestSet.weight > 0) {
      records.push(`${name} · mejor serie: ${roundOne_(current.bestSet.weight)} kg × ${current.bestSet.reps} (e1RM ${roundOne_(current.e1rm)} kg)`);
    }
    if (current.volume > previousMaxWorkoutVolume * 1.01 && previousMaxWorkoutVolume > 0) {
      records.push(`${name} · mayor volumen: ${Math.round(current.volume).toLocaleString('es-ES')} kg`);
    }
    if (current.maxLoad > 0 && currentSameLoadReps > previousSameLoadReps && previousSameLoadReps > 0) {
      records.push(`${name} · más repeticiones con ${roundOne_(current.maxLoad)} kg: ${currentSameLoadReps}`);
    }

    if (current.maxLoad > latest.maxLoad + 0.001) {
      improvements.push(`${name}: +${roundOne_(current.maxLoad - latest.maxLoad)} kg`);
    } else if (Math.abs(current.maxLoad - latest.maxLoad) < 0.001 && current.totalReps > latest.totalReps) {
      improvements.push(`${name}: +${current.totalReps - latest.totalReps} repeticiones totales`);
    } else if (latest.volume > 0 && current.volume > latest.volume * 1.03) {
      improvements.push(`${name}: +${Math.round((current.volume / latest.volume - 1) * 100)}% de volumen`);
    }
  });

  return {
    improvements: Array.from(new Set(improvements)),
    records: Array.from(new Set(records)),
  };
}

function orderedSeriesServer_(rows) {
  return (rows || [])
    .filter(r => toBoolean_(r.Completada))
    .slice()
    .sort((a,b) => (Number(a.NumeroSerie) || 0) - (Number(b.NumeroSerie) || 0))
    .map((r, index) => ({
      number: Number(r.NumeroSerie) || index + 1,
      weight: Math.max(0, normalizeNumber_(r.Peso) || 0),
      reps: Math.max(0, Number(r.RepsRealizadas) || 0),
      rir: toOptionalNumber_(r.RIRReal),
    }));
}

function roundToHalfServer_(value) {
  return Math.max(0, Math.round(Number(value || 0) * 2) / 2);
}

function buildLadderDecisionServer_(ss, plan, rows) {
  const sets = orderedSeriesServer_(rows);
  const numSeries = Math.max(1, Number(plan.SeriesObjetivo) || sets.length || 1);
  const repsRange = parseRangeServer_(plan.RepsObjetivo);
  const type = progressionTypeServer_(plan);
  const increment = Math.max(0.5, progressionIncrementServer_(ss, plan));
  const reduction = Math.max(0.5, normalizeNumber_(plan.ReduccionCarga) || increment / 2);
  const minLoad = Math.max(0, normalizeNumber_(plan.CargaMinima) || 0);
  const unit = cleanText_(plan.UnidadCarga || 'kg', 30);
  const planLoad = Math.max(0, normalizeNumber_(plan.PesoActual || plan['Peso Actual']) || 0);

  if (type === 'manual') {
    const base = (sets[0] && sets[0].weight) || planLoad;
    const weights = Array.from({length:numSeries}, (_,i) => (sets[i] && sets[i].weight) || base || 0);
    return { action:'manual', weights, unit, reason:'progresión manual' };
  }

  if (!sets.length) {
    return {
      action:'start',
      weights:Array.from({length:numSeries}, () => planLoad || 0),
      unit,
      reason:'empieza intentando mantener la misma carga; baja solo en la serie siguiente si no alcanzas el mínimo'
    };
  }

  const topWeight = (sets[0] && sets[0].weight) || Math.max.apply(null, sets.map(s => s.weight));
  let leadingConsolidated = 0;
  for (let i=0; i<Math.min(numSeries, sets.length); i++) {
    const set = sets[i];
    if (Math.abs(set.weight - topWeight) < 0.001 && set.reps >= repsRange.min) leadingConsolidated++;
    else break;
  }

  const allConsolidated = sets.length >= numSeries && leadingConsolidated >= numSeries;
  const weights = Array.from({length:numSeries}, (_,i) => {
    const historic = sets[i] && sets[i].weight;
    return historic > 0 ? historic : roundToHalfServer_(Math.max(minLoad, topWeight - reduction * i));
  });

  let action = 'consolidate';
  let reason = '';
  if (allConsolidated) {
    weights[0] = roundToHalfServer_(topWeight + increment);
    for (let i=1; i<numSeries; i++) weights[i] = topWeight;
    action = 'up-first';
    reason = `carga consolidada en ${numSeries}/${numSeries} series; sube solo S1`;
  } else {
    weights[0] = topWeight;
    if (leadingConsolidated > 0 && leadingConsolidated < numSeries) {
      weights[leadingConsolidated] = topWeight;
      reason = `carga consolidada en ${leadingConsolidated}/${numSeries} series; intenta extenderla a S${leadingConsolidated + 1}`;
    } else {
      reason = 'mantén la carga alta en S1 y baja únicamente en la serie siguiente si no alcanzas el mínimo';
    }
    for (let i=1; i<numSeries; i++) {
      weights[i] = roundToHalfServer_(Math.max(minLoad, Math.min(weights[i], weights[i-1])));
    }
  }

  return { action, weights, unit, reason };
}

function buildNextSessionDecisions_(ss, currentSeries, workoutId, planById) {
  const currentGroups = new Map();
  currentSeries.forEach(r => {
    const key = String(r.ID_EjercicioPlan || '');
    if (!currentGroups.has(key)) currentGroups.set(key, []);
    currentGroups.get(key).push(r);
  });
  const decisions = [];
  currentGroups.forEach((rows, exerciseId) => {
    const plan = planById.get(exerciseId) || {};
    const name = actualExerciseName_(rows[0], planById);
    const decision = buildLadderDecisionServer_(ss, plan, rows);
    const loadText = decision.weights.map((value, index) => `S${index + 1} ${roundOne_(value)}`).join(' · ');
    decisions.push(`${name}: ${loadText} ${decision.unit} — ${decision.reason}`);
  });
  return decisions;
}

function analyseWorkoutProgress_(ss, currentSeries, workoutId, planById) {
  const allSeries = sheetToObjectsRaw_(ss, 'RegistroSeries').filter(r => String(r.ID_Entrenamiento) !== workoutId && toBoolean_(r.Completada));
  const currentGroups = groupSeriesByActualExercise_(currentSeries, planById);
  const previousGroups = groupSeriesByActualExercise_(allSeries, planById);
  const improvements = [];
  const records = [];
  currentGroups.forEach((rows, key) => {
    const name = actualExerciseName_(rows[0], planById);
    const currentMax = Math.max(0, ...rows.map(r => normalizeNumber_(r.Peso)));
    const currentReps = rows.reduce((sum,r) => sum + Number(r.RepsRealizadas || 0), 0);
    const currentVolume = rows.reduce((sum,r) => sum + normalizeNumber_(r.Peso) * Number(r.RepsRealizadas || 0), 0);
    const previous = previousGroups.get(key) || [];
    if (!previous.length) return;
    const priorMax = Math.max(0, ...previous.map(r => normalizeNumber_(r.Peso)));
    if (currentMax > priorMax) records.push(`${name}: récord de carga ${roundOne_(currentMax)} kg`);
    const groupedWorkouts = new Map();
    previous.forEach(r => {
      const k = String(r.ID_Entrenamiento || normalizeDateKey_(r.Fecha) || r.Timestamp || 'sin-id');
      if (!groupedWorkouts.has(k)) groupedWorkouts.set(k, []);
      groupedWorkouts.get(k).push(r);
    });
    const latest = [...groupedWorkouts.values()].sort((a,b) => latestSeriesTime_(b) - latestSeriesTime_(a))[0] || [];
    const latestMax = Math.max(0, ...latest.map(r => normalizeNumber_(r.Peso)));
    const latestReps = latest.reduce((sum,r) => sum + Number(r.RepsRealizadas || 0), 0);
    const latestVolume = latest.reduce((sum,r) => sum + normalizeNumber_(r.Peso) * Number(r.RepsRealizadas || 0), 0);
    if (currentMax > latestMax) improvements.push(`${name}: +${roundOne_(currentMax-latestMax)} kg`);
    else if (currentMax === latestMax && currentReps > latestReps) improvements.push(`${name}: +${currentReps-latestReps} repeticiones`);
    else if (currentVolume > latestVolume * 1.03) improvements.push(`${name}: +${Math.round((currentVolume/latestVolume-1)*100)}% volumen`);
  });
  return { improvements, records };
}

function groupSeriesByActualExercise_(rows, planById) {
  const result = new Map();
  rows.forEach(r => {
    const key = normalizeExerciseName_(actualExerciseName_(r, planById));
    if (!key) return;
    if (!result.has(key)) result.set(key, []);
    result.get(key).push(r);
  });
  return result;
}

function actualExerciseName_(row, planById) {
  const plan = planById.get(String(row.ID_EjercicioPlan)) || {};
  return String(row.NombreEjercicioReal || plan.NombreEjercicio || row.ID_EjercicioPlan || 'Ejercicio');
}

function latestSeriesTime_(rows) {
  return Math.max(0, ...rows.map(r => { const d = parseDate_(r.Timestamp || r.Fecha); return d ? d.getTime() : 0; }));
}

function calculateWorkoutMuscles_(ss, series, planById) {
  const mapRows = sheetToObjectsRaw_(ss, 'MapaMuscular');
  const mapping = new Map(mapRows.map(r => [normalizeExerciseName_(r.NombreEjercicio), r]));
  const totals = {};
  series.forEach(row => {
    const plan = planById.get(String(row.ID_EjercicioPlan)) || {};
    const name = actualExerciseName_(row, planById);
    const map = mapping.get(normalizeExerciseName_(name));
    const primary = String((map && map.MusculoPrincipal) || row.GrupoMuscularReal || plan.GrupoMuscular || 'Otro');
    addMuscleVolume_(totals, primary, normalizeNumber_((map && map.CoefPrincipal) || 1), true);
    if (map && map.MusculoSecundario1) addMuscleVolume_(totals, String(map.MusculoSecundario1), normalizeNumber_(map.CoefSecundario1), false);
    if (map && map.MusculoSecundario2) addMuscleVolume_(totals, String(map.MusculoSecundario2), normalizeNumber_(map.CoefSecundario2), false);
  });
  const items = Object.keys(totals).map(name => ({ name, direct: roundOne_(totals[name].direct), indirect: roundOne_(totals[name].indirect), total: roundOne_(totals[name].direct + totals[name].indirect) })).sort((a,b) => b.total-a.total);
  return { items, text: items.map(i => `${i.name} ${i.total}`).join(' | ') };
}

function addMuscleVolume_(totals, name, amount, direct) {
  if (!name || !amount) return;
  if (!totals[name]) totals[name] = { direct: 0, indirect: 0 };
  totals[name][direct ? 'direct' : 'indirect'] += amount;
}

function roundOne_(value) { return Math.round(Number(value || 0) * 10) / 10; }

function setSessionFinalState_(ss, sessionId, status, dateKey) {
  const sheet=ss.getSheetByName('Sesiones'), headers=getHeaders_(sheet), idCol=headers.indexOf('ID_Sesion')+1, stateCol=headers.indexOf('Estado')+1, dateCol=headers.indexOf('FechaRealizada')+1;
  if(idCol<=0||stateCol<=0)return; const ids=sheet.getLastRow()>1?sheet.getRange(2,idCol,sheet.getLastRow()-1,1).getValues().flat():[]; const idx=ids.findIndex(v=>String(v)===sessionId); if(idx<0)return;
  sheet.getRange(idx+2,stateCol).setValue(status==='Completa'?'Completada':'Finalizada parcial'); if(dateCol>0)sheet.getRange(idx+2,dateCol).setValue(parseDateOrToday_(dateKey));
}

function isFutureDateKey_(key) {
  const d=parseDate_(key); if(!d)return false; const today=new Date(); today.setHours(0,0,0,0); d.setHours(0,0,0,0); return d>today;
}

function serializeObject_(object) {
  const out={}; Object.keys(object).forEach(key=>out[key]=serializeCell_(key,object[key])); return out;
}

function saveLegacyCalendar_(ss, row, email) {
  const id = String(row.ID_EjercicioPlan || '');
  return saveCalendarActivity_(ss, {
    date: id.replace(/^CAL-/, '') || row.Fecha,
    activityType: row.ComentarioGeneral,
  }, email);
}

function saveMeasures_(ss, payload, email) {
  const row = payload.row || {};
  const dateKey = normalizeDateKey_(row.Fecha || new Date());
  const sheet = ss.getSheetByName('Medidas');
  if (!sheet) throw new Error('No existe la hoja Medidas.');

  const headers = getHeaders_(sheet);
  const measureFields = ['Peso', 'Cintura', 'Gluteo', 'Muslo', 'MusloMedio', 'Biceps', 'Pecho'];
  const object = { Fecha: parseDateOrToday_(dateKey) };
  let valid = 0;

  measureFields.forEach(field => {
    const value = toOptionalNumber_(row[field]);
    object[field] = value === null ? '' : boundedNumber_(value, 0, 500, field);
    if (value !== null && value > 0) valid += 1;
  });
  if (!valid) throw new Error('Introduce al menos una medida válida.');

  const dateCol = headers.indexOf('Fecha') + 1;
  if (dateCol <= 0) throw new Error('La hoja Medidas no contiene la columna Fecha.');
  const dates = sheet.getLastRow() > 1
    ? sheet.getRange(2, dateCol, sheet.getLastRow() - 1, 1).getValues().flat()
    : [];
  const existing = dates.findIndex(value => normalizeDateKey_(value) === dateKey);
  const rowValues = headers.map(header => object[header] !== undefined ? object[header] : '');

  if (existing >= 0) {
    sheet.getRange(existing + 2, 1, 1, headers.length).setValues([rowValues]);
    return { ok: true, action: 'updated', date: dateKey, user: email };
  }

  sheet.getRange(sheet.getLastRow() + 1, 1, 1, headers.length).setValues([rowValues]);
  return { ok: true, action: 'inserted', date: dateKey, user: email };
}

function updateSessionStateForExercise_(ss, exerciseId) {
  const plan = getExercisePlan_(ss, exerciseId);
  if (!plan) return null;
  return updateSessionState_(ss, plan.ID_Sesion);
}

function updateSessionState_(ss, sessionId) {
  const exercises = sheetToObjectsRaw_(ss, 'EjerciciosPlan')
    .filter(row => String(row.ID_Sesion) === String(sessionId));
  const exerciseIds = new Set(exercises.map(row => String(row.ID_EjercicioPlan)));

  const completed = new Set(
    sheetToObjectsRaw_(ss, 'RegistroEjercicios')
      .filter(row => exerciseIds.has(String(row.ID_EjercicioPlan)) && toBoolean_(row.EjercicioCompletado))
      .map(row => String(row.ID_EjercicioPlan))
  );

  const state = completed.size === 0
    ? 'No empezada'
    : completed.size >= exercises.length
      ? 'Completada'
      : 'En curso';

  const sheet = ss.getSheetByName('Sesiones');
  const headers = getHeaders_(sheet);
  const idCol = headers.indexOf('ID_Sesion') + 1;
  const stateCol = headers.indexOf('Estado') + 1;
  const dateCol = headers.indexOf('FechaRealizada') + 1;
  if (idCol <= 0 || stateCol <= 0) return null;

  const ids = sheet.getRange(2, idCol, Math.max(sheet.getLastRow() - 1, 0), 1).getValues().flat();
  const idx = ids.findIndex(value => String(value) === String(sessionId));
  if (idx < 0) return null;

  const rowNumber = idx + 2;
  sheet.getRange(rowNumber, stateCol).setValue(state);
  if (dateCol > 0) {
    sheet.getRange(rowNumber, dateCol).setValue(state === 'Completada' ? new Date() : '');
  }
  return { sessionId, state, completed: completed.size, total: exercises.length };
}

function recalculateAllSessionStates_(ss) {
  // Solo recalcula sesiones que ya tienen registros. Así no se altera el
  // histórico M1-M4, que en el libro está marcado como completado pero no
  // dispone de RegistroEjercicios detallado.
  const registeredExerciseIds = new Set(
    sheetToObjectsRaw_(ss, 'RegistroEjercicios')
      .filter(row => !String(row.ID_EjercicioPlan || '').startsWith('CAL-'))
      .map(row => String(row.ID_EjercicioPlan || ''))
  );
  const sessionIds = new Set(
    sheetToObjectsRaw_(ss, 'EjerciciosPlan')
      .filter(row => registeredExerciseIds.has(String(row.ID_EjercicioPlan || '')))
      .map(row => String(row.ID_Sesion || ''))
      .filter(Boolean)
  );

  let updated = 0;
  sessionIds.forEach(sessionId => {
    const result = updateSessionState_(ss, sessionId);
    if (result) updated += 1;
  });
  return updated;
}

function migrateLegacyCalendar_(ss, email) {
  const legacy = sheetToObjectsRaw_(ss, 'RegistroEjercicios')
    .filter(row => String(row.ID_EjercicioPlan || '').startsWith('CAL-'));
  if (!legacy.length) return 0;

  const latestByDate = new Map();
  legacy.forEach(row => {
    const key = normalizeDateKey_(String(row.ID_EjercicioPlan).replace(/^CAL-/, '') || row.Fecha);
    if (!key) return;
    const timestamp = parseTimestampOrNow_(row.Timestamp || row.Fecha, new Date(0)).getTime();
    const previous = latestByDate.get(key);
    if (!previous || timestamp >= previous.timestamp) {
      latestByDate.set(key, {
        timestamp,
        type: String(row.ComentarioGeneral || 'descanso')
      });
    }
  });

  let migrated = 0;
  latestByDate.forEach((value, key) => {
    try {
      saveCalendarActivity_(ss, { date: key, activityType: value.type }, email);
      migrated += 1;
    } catch (error) {
      console.warn('No se pudo migrar actividad ' + key + ': ' + error.message);
    }
  });
  return migrated;
}

/**
 * Elimina únicamente duplicados lógicos exactos de RegistroSeries,
 * conservando el registro más reciente. Crea una copia de seguridad.
 * No se ejecuta automáticamente.
 */
function limpiarDuplicadosExactos() {
  assertAuthorized_();
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(15000)) throw new Error('La hoja está ocupada.');
  try {
    const ss = getSpreadsheet_();
    const sheet = ss.getSheetByName('RegistroSeries');
    const backupName = makeBackupName_('RegistroSeries');
    sheet.copyTo(ss).setName(backupName);

    const data = sheet.getDataRange().getValues();
    const headers = data[0].map(String);
    const indexes = Object.fromEntries(headers.map((header, index) => [header, index]));
    const seen = new Set();
    const rowsToDelete = [];

    for (let rowIndex = data.length - 1; rowIndex >= 1; rowIndex -= 1) {
      const row = data[rowIndex];
      if (!row.some(value => value !== '' && value !== null)) continue;
      const key = [
        row[indexes.ID_EjercicioPlan], normalizeDateKey_(row[indexes.Fecha]),
        row[indexes.NumeroSerie], normalizeNumber_(row[indexes.Peso]),
        row[indexes.RepsRealizadas], normalizeNumber_(row[indexes.RIRReal]),
        toBoolean_(row[indexes.Completada])
      ].join('|');
      if (seen.has(key)) rowsToDelete.push(rowIndex + 1);
      else seen.add(key);
    }

    rowsToDelete.sort((a, b) => b - a).forEach(rowNumber => sheet.deleteRow(rowNumber));
    return { ok: true, deleted: rowsToDelete.length, backupSheet: backupName };
  } finally {
    lock.releaseLock();
  }
}

/** Devuelve los registros cuyo ID de semana no coincide con su fecha. */
function previewWeekMisalignments() {
  assertAuthorized_();
  return processWeekMisalignments_(getSpreadsheet_(), false);
}

/**
 * Corrige los desfases de semana detectados, creando antes copias de seguridad.
 * Solo cambia el ID_EjercicioPlan cuando existe el ejercicio equivalente en la
 * semana calculada (mismo mesociclo, día y número de ejercicio).
 */
function repararDesfasesSemana() {
  assertAuthorized_();
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(15000)) throw new Error('La hoja está ocupada.');
  try {
    return processWeekMisalignments_(getSpreadsheet_(), true);
  } finally {
    lock.releaseLock();
  }
}

function processWeekMisalignments_(ss, applyChanges) {
  const config = sheetToObjectsRaw_(ss, 'Configuracion')[0] || {};
  const current = String(config.MesocicloActual || '');
  const start = parseDate_(config.FechaInicio);
  if (!current || !start) throw new Error('Configuracion no contiene MesocicloActual y FechaInicio válidos.');

  const planIds = new Set(sheetToObjectsRaw_(ss, 'EjerciciosPlan').map(row => String(row.ID_EjercicioPlan)));
  const startDay = new Date(start.getFullYear(), start.getMonth(), start.getDate()).getTime();
  const changes = [];
  const targets = ['RegistroSeries', 'RegistroEjercicios'];
  const backups = [];

  targets.forEach(sheetName => {
    const sheet = ss.getSheetByName(sheetName);
    const data = sheet.getDataRange().getValues();
    const headers = data[0].map(String);
    const idCol = headers.indexOf('ID_EjercicioPlan');
    const dateCol = headers.indexOf('Fecha');
    if (idCol < 0 || dateCol < 0) return;

    const sheetChanges = [];
    for (let index = 1; index < data.length; index += 1) {
      const id = String(data[index][idCol] || '');
      const match = id.match(/^(M\d+)-S(\d+)-(D\d+)-(E\d+)$/);
      if (!match || match[1] !== current) continue;
      const date = parseDate_(data[index][dateCol]);
      if (!date) continue;
      const day = new Date(date.getFullYear(), date.getMonth(), date.getDate()).getTime();
      const expectedWeek = Math.floor((day - startDay) / 86400000 / 7) + 1;
      if (expectedWeek < 1 || expectedWeek > 9 || Number(match[2]) === expectedWeek) continue;

      const targetId = `${match[1]}-S${expectedWeek}-${match[3]}-${match[4]}`;
      if (!planIds.has(targetId)) continue;
      sheetChanges.push({ row: index + 1, from: id, to: targetId, date: formatDateOnly_(date) });
    }

    if (applyChanges && sheetChanges.length) {
      const backupName = makeBackupName_(sheetName);
      sheet.copyTo(ss).setName(backupName);
      backups.push(backupName);
      sheetChanges.forEach(change => sheet.getRange(change.row, idCol + 1).setValue(change.to));
    }
    sheetChanges.forEach(change => changes.push({ sheet: sheetName, ...change }));
  });

  if (applyChanges) recalculateAllSessionStates_(ss);
  return { ok: true, applied: Boolean(applyChanges), count: changes.length, changes, backups };
}

function syncCurrentMesocycleDates_(ss) {
  const config = sheetToObjectsRaw_(ss, 'Configuracion')[0] || {};
  const current = String(config.MesocicloActual || '');
  const start = parseDate_(config.FechaInicio);
  if (!current || !start) return { updated: false };

  const sheet = ss.getSheetByName('Mesociclos');
  if (!sheet) return { updated: false };
  const headers = getHeaders_(sheet);
  const idCol = headers.indexOf('ID_Mesociclo') + 1;
  const startCol = headers.indexOf('FechaInicio') + 1;
  const endCol = headers.indexOf('FechaFin') + 1;
  const weeksCol = headers.indexOf('NumeroSemanas') + 1;
  if ([idCol, startCol, endCol, weeksCol].some(column => column <= 0)) return { updated: false };

  const ids = sheet.getRange(2, idCol, sheet.getLastRow() - 1, 1).getValues().flat();
  const index = ids.findIndex(value => String(value) === current);
  if (index < 0) return { updated: false };
  const row = index + 2;
  const weeks = positiveInt_(sheet.getRange(row, weeksCol).getValue() || 4, 1, 52, 'NumeroSemanas');
  const end = new Date(start.getFullYear(), start.getMonth(), start.getDate() + weeks * 7 - 1);
  sheet.getRange(row, startCol).setValue(new Date(start.getFullYear(), start.getMonth(), start.getDate()));
  sheet.getRange(row, endCol).setValue(end);
  return { updated: true, mesocycle: current, start: formatDateOnly_(start), end: formatDateOnly_(end) };
}

function makeBackupName_(base) {
  const suffix = Utilities.formatDate(new Date(), RIR_CONFIG.TIME_ZONE, 'yyyyMMdd_HHmmss');
  return (base + '_Backup_' + suffix).slice(0, 99);
}

function diagnoseRIRTrainer() {
  assertAuthorized_();
  return diagnoseWorkbook_(getSpreadsheet_());
}

function diagnoseWorkbook_(ss) {
  const config = sheetToObjectsRaw_(ss, 'Configuracion')[0] || {};
  const mesocycles = sheetToObjectsRaw_(ss, 'Mesociclos');
  const current = String(config.MesocicloActual || '');
  const currentMeso = mesocycles.find(row => String(row.ID_Mesociclo) === current);
  const series = sheetToObjectsRaw_(ss, 'RegistroSeries');
  const exercises = sheetToObjectsRaw_(ss, 'RegistroEjercicios');

  const duplicateSeries = countLogicalDuplicates_(series, row => [
    row.ID_EjercicioPlan, normalizeDateKey_(row.Fecha), row.NumeroSerie,
    normalizeNumber_(row.Peso), row.RepsRealizadas, normalizeNumber_(row.RIRReal)
  ].join('|'));
  const calendarByDate = {};
  exercises.filter(row => String(row.ID_EjercicioPlan || '').startsWith('CAL-')).forEach(row => {
    const key = String(row.ID_EjercicioPlan);
    calendarByDate[key] = (calendarByDate[key] || 0) + 1;
  });
  const duplicateCalendarDays = Object.keys(calendarByDate).filter(key => calendarByDate[key] > 1).length;

  let currentMesoDateMismatch = false;
  if (currentMeso && config.FechaInicio && currentMeso.FechaInicio) {
    currentMesoDateMismatch = normalizeDateKey_(config.FechaInicio) !== normalizeDateKey_(currentMeso.FechaInicio);
  }

  const weekMisalignedSeries = countWeekMisalignments_(series, config, current);
  const weekMisalignedExercises = countWeekMisalignments_(
    exercises.filter(row => !String(row.ID_EjercicioPlan || '').startsWith('CAL-')),
    config,
    current
  );

  return {
    currentMesocycle: current,
    currentMesoDateMismatch,
    duplicateLogicalSeries: duplicateSeries,
    duplicateCalendarDays,
    weekMisalignedSeries,
    weekMisalignedExercises,
    note: 'El diagnóstico no modifica ni elimina filas.',
  };
}

function countWeekMisalignments_(rows, config, currentMesocycle) {
  const start = parseDate_(config.FechaInicio);
  if (!start || !currentMesocycle) return 0;
  const startDay = new Date(start.getFullYear(), start.getMonth(), start.getDate()).getTime();
  let mismatches = 0;

  rows.forEach(row => {
    const id = String(row.ID_EjercicioPlan || '');
    const match = id.match(new RegExp('^' + currentMesocycle.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + '-S(\\d+)-'));
    if (!match) return;
    const date = parseDate_(row.Fecha);
    if (!date) return;
    const day = new Date(date.getFullYear(), date.getMonth(), date.getDate()).getTime();
    const expectedWeek = Math.floor((day - startDay) / 86400000 / 7) + 1;
    if (expectedWeek >= 1 && expectedWeek <= 9 && Number(match[1]) !== expectedWeek) mismatches += 1;
  });
  return mismatches;
}



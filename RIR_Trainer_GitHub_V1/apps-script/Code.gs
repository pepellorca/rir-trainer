    config: sheetToObjects_(ss, 'Configuracion'), sesiones: sheetToObjects_(ss, 'Sesiones'),
    ejercicios: sheetToObjects_(ss, 'EjerciciosPlan'),
    registroSeries: dedupeRowsById_(sheetToObjects_(ss, 'RegistroSeries'), 'ID_RegistroSerie'),
    registroEjercicios: dedupeRowsById_(registroEjercicios, 'ID_RegistroEjercicio'),
    registroEntrenamientos: workoutSheet ? dedupeRowsById_(sheetToObjects_(ss, 'RegistroEntrenamientos'), 'ID_Entrenamiento') : [],
    calendarioActividades,
    calentamientos: sheetToObjects_(ss, 'Calentamientos'),
    registroCalentamientos: dedupeRowsById_(sheetToObjects_(ss, 'RegistroCalentamientos'), 'ID_RegistroCalentamiento'),
    sustituciones: sheetToObjects_(ss, 'SustitucionesSesion').filter(row => String(row.Estado || 'activo').toLowerCase() !== 'eliminado'),
    mapaMuscular: sheetToObjects_(ss, 'MapaMuscular'),
    medidas: sheetToObjects_(ss, 'Medidas'),
  };
}


/**
 * Punto único de escritura invocado por google.script.run.
 * Todas las operaciones requieren usuario autorizado, validación y bloqueo.
 */
function apiWrite(payload) {
  const email = assertAuthorized_();
  if (!payload || typeof payload !== 'object') throw new Error('Petición vacía o inválida.');

  const lock = LockService.getScriptLock();
  if (!lock.tryLock(15000)) throw new Error('La hoja está ocupada. Vuelve a intentarlo.');

  try {
    const ss = getSpreadsheet_();
    const type = String(payload.type || '');

    switch (type) {
      case 'exerciseBatch':
        return saveExerciseBatch_(ss, payload, email);
      case 'seriesUpsert':
        return saveSeriesUpsert_(ss, payload, email);
      case 'workoutStart':
        return saveWorkoutStart_(ss, payload, email);
      case 'calendar':
        return saveCalendarActivity_(ss, payload, email);
      case 'calendarDelete':
        return deleteCalendarActivity_(ss, payload, email);
      case 'finishWorkout':
        return saveWorkoutSummary_(ss, payload, email);
      case 'warmupBatch':
        return saveWarmupBatch_(ss, payload, email);
      case 'substitution':
        return saveSubstitution_(ss, payload, email);
      case 'substitutionDelete':
        return deleteSubstitution_(ss, payload, email);
      case 'measures':
        return saveMeasures_(ss, payload, email);
      case 'syncAudit':
        return getSyncAuditV7_(ss, payload, email);

      // Compatibilidad con la cola local de versiones anteriores.
      case 'series':
        return saveLegacySeries_(ss, payload, email);
      case 'ejercicio':
        if (String(payload.row && payload.row.ID_EjercicioPlan || '').startsWith('CAL-')) {
          return saveLegacyCalendar_(ss, payload.row, email);
        }
        return saveLegacyExercise_(ss, payload, email);
      case 'medidas':
        return saveMeasures_(ss, { row: payload.row }, email);
      default:
        throw new Error('Tipo de operación no permitido: ' + type);
    }
  } finally {
    lock.releaseLock();
  }
}


/**
 * V7 — inicia el entrenamiento en el servidor en el momento en que el usuario
 * pulsa Empezar. La fila se reutiliza al finalizar, por lo que la duración no
 * depende de la primera serie ni del almacenamiento local del navegador.
 */
function saveWorkoutStart_(ss, payload, email) {
  const workoutId = requiredId_(payload.ID_Entrenamiento, 'ID_Entrenamiento');
  const sessionId = requiredId_(payload.ID_Sesion, 'ID_Sesion');
  const dateKey = normalizeDateKey_(payload.Fecha);
  if (!/^\d{4}-\d{2}-\d{2}$/.test(dateKey) || isFutureDateKey_(dateKey)) {
    throw new Error('La fecha de inicio del entrenamiento no es válida.');
  }
  const session = sheetToObjectsRaw_(ss, 'Sesiones').find(r => String(r.ID_Sesion) === sessionId);
  if (!session) throw new Error('La sesión no existe.');

  const sheet = ensureSheet_(ss, 'RegistroEntrenamientos', RIR_HEADERS.RegistroEntrenamientos);
  ensureHeaders_(ss, 'RegistroEntrenamientos', RIR_HEADERS.RegistroEntrenamientos);
  const existing = findObjectByColumns_(sheet, {
    ID_Entrenamiento: workoutId,
  });
  const finalState = String(existing && existing.Estado || '').toLowerCase();
  if (finalState.includes('completa') || finalState.includes('parcial') || finalState.includes('final')) {
    return { ok: true, alreadyFinalized: true, workout: serializeObject_(existing) };
  }

  const start = existing && existing.HoraInicio
    ? parseTimestampOrNow_(existing.HoraInicio, new Date())
    : parseTimestampOrNow_(payload.HoraInicio, new Date());
  const object = Object.assign({}, existing || {}, {
    ID_Entrenamiento: workoutId,
    ID_Sesion: sessionId,
    Fecha: parseDateOrToday_(dateKey),
    HoraInicio: start,
    Estado: 'En curso',
    TiempoDescansoSeg: Math.max(0, Math.round(normalizeNumber_(payload.TiempoDescansoSeg) || 0)),
    FechaModificacion: new Date(),
    Usuario: email,
  });
  const result = upsertObjectByColumns_(sheet, object, ['ID_Entrenamiento']);
  SpreadsheetApp.flush();
  return { ok: true, action: result.action, workout: serializeObject_(result.object) };
}

/**
 * V7 — guardado idempotente de una serie. La clave lógica es
 * entrenamiento + ejercicio + número de serie. Repetir la operación actualiza
 * la fila existente en vez de crear duplicados.
 */
function saveSeriesUpsert_(ss, payload, email) {
  const raw = payload.row || {};
  const workoutId = requiredId_(raw.ID_Entrenamiento || payload.ID_Entrenamiento, 'ID_Entrenamiento');
  const exerciseId = requiredId_(raw.ID_EjercicioPlan, 'ID_EjercicioPlan');
  const plan = getExercisePlan_(ss, exerciseId);
  if (!plan) throw new Error('El ejercicio no existe en EjerciciosPlan.');
  const maxSeries = positiveInt_(plan.SeriesObjetivo, 1, 20, 'SeriesObjetivo');
  const seriesNumber = positiveInt_(raw.NumeroSerie, 1, maxSeries, 'NumeroSerie');
  const dateKey = normalizeDateKey_(raw.Fecha || payload.Fecha);
  if (!/^\d{4}-\d{2}-\d{2}$/.test(dateKey) || isFutureDateKey_(dateKey)) {
    throw new Error('La fecha de la serie no es válida.');
  }
  const completed = toBoolean_(raw.Completada);
  const now = new Date();
  const logicalKey = workoutId + '|' + exerciseId + '|S' + seriesNumber;
  const safeSeriesId = cleanText_(raw.ID_RegistroSerie, 160) || ('RS-' + Utilities.getUuid());

  const seriesObject = {
    ID_RegistroSerie: safeSeriesId,
    ID_EjercicioPlan: exerciseId,
    Fecha: parseDateOrToday_(dateKey),
    Timestamp: parseTimestampOrNow_(raw.Timestamp, now),
    NumeroSerie: seriesNumber,
    Peso: boundedNumber_(raw.Peso, 0, 1000, 'Peso'),
    RepsRealizadas: positiveInt_(raw.RepsRealizadas, 0, 1000, 'RepsRealizadas'),
    RIRReal: boundedNumber_(raw.RIRReal, 0, 10, 'RIRReal'),
    ComentarioSerie: cleanText_(raw.ComentarioSerie, RIR_CONFIG.MAX_COMMENT_LENGTH),
    Completada: completed,
    ID_Entrenamiento: workoutId,
    Usuario: email,
    NombreEjercicioReal: cleanText_(raw.NombreEjercicioReal || plan.NombreEjercicio, 180),
    GrupoMuscularReal: cleanText_(raw.GrupoMuscularReal || plan.GrupoMuscular, 80),
    ClaveSerie: logicalKey,
    FechaModificacion: now,
  };

  const seriesSheet = ss.getSheetByName('RegistroSeries');
  ensureHeaders_(ss, 'RegistroSeries', RIR_HEADERS.RegistroSeries);
  const incomingRevision = Math.max(0, Number(raw.RevisionCliente) || 0);
  seriesObject.RevisionCliente = incomingRevision;
  const existingSeries = findObjectByColumns_(seriesSheet, {
    ID_Entrenamiento: workoutId,
    ID_EjercicioPlan: exerciseId,
    NumeroSerie: seriesNumber,
  });
  const existingRevision = Math.max(0, Number(existingSeries && existingSeries.RevisionCliente) || 0);
  if (existingSeries && incomingRevision < existingRevision) {
    return {
      ok: true,
      staleIgnored: true,
      seriesAction: 'ignored-stale',
      series: serializeObject_(existingSeries),
      exercise: null,
      completedSeries: 0,
      exerciseComplete: false,
    };
  }
  const seriesResult = upsertObjectByColumns_(seriesSheet, seriesObject, [
    'ID_Entrenamiento', 'ID_EjercicioPlan', 'NumeroSerie'
  ], ['ID_RegistroSerie']);

  const allWorkoutSeries = sheetToObjectsRaw_(ss, 'RegistroSeries').filter(r =>
    String(r.ID_Entrenamiento) === workoutId &&
    String(r.ID_EjercicioPlan) === exerciseId &&
    toBoolean_(r.Completada)
  );
  const exerciseComplete = new Set(allWorkoutSeries.map(r => Number(r.NumeroSerie))).size >= maxSeries;
  const exerciseRaw = payload.exercise || {};
  const exerciseObject = {
    ID_RegistroEjercicio: cleanText_(exerciseRaw.ID_RegistroEjercicio, 160) || ('RE-' + Utilities.getUuid()),
    ID_EjercicioPlan: exerciseId,
    Fecha: parseDateOrToday_(dateKey),
    ComentarioGeneral: cleanText_(exerciseRaw.ComentarioGeneral || raw.ComentarioSerie, RIR_CONFIG.MAX_COMMENT_LENGTH),
    EjercicioCompletado: exerciseComplete,
    ID_Entrenamiento: workoutId,
    Timestamp: now,
    Usuario: email,
    NombreEjercicioReal: cleanText_(raw.NombreEjercicioReal || exerciseRaw.NombreEjercicioReal || plan.NombreEjercicio, 180),
    GrupoMuscularReal: cleanText_(raw.GrupoMuscularReal || exerciseRaw.GrupoMuscularReal || plan.GrupoMuscular, 80),
    FechaModificacion: now,
  };
  const exerciseSheet = ss.getSheetByName('RegistroEjercicios');
  ensureHeaders_(ss, 'RegistroEjercicios', RIR_HEADERS.RegistroEjercicios);
  const exerciseResult = upsertObjectByColumns_(exerciseSheet, exerciseObject, [
    'ID_Entrenamiento', 'ID_EjercicioPlan'
  ], ['ID_RegistroEjercicio']);

  const sessionState = updateSessionStateForExercise_(ss, exerciseId);
  SpreadsheetApp.flush();
  return {
    ok: true,
    seriesAction: seriesResult.action,
    exerciseAction: exerciseResult.action,
    series: serializeObject_(seriesResult.object),
    exercise: serializeObject_(exerciseResult.object),
    completedSeries: allWorkoutSeries.length,
    exerciseComplete,
    sessionState,
  };
}

function saveExerciseBatch_(ss, payload, email) {
  const rows = Array.isArray(payload.rows) ? payload.rows : [];
  const exerciseRow = payload.row || {};
  if (!rows.length || rows.length > RIR_CONFIG.MAX_BATCH_SERIES) {
    throw new Error('El número de series del lote no es válido.');
  }

  const exerciseId = cleanText_(exerciseRow.ID_EjercicioPlan, 120);
  const plan = getExercisePlan_(ss, exerciseId);
  if (!plan) throw new Error('El ejercicio no existe en EjerciciosPlan.');

  const maxSeries = positiveInt_(plan.SeriesObjetivo, 1, 20, 'SeriesObjetivo');
  const batchId = cleanText_(exerciseRow.ID_Entrenamiento || rows[0].ID_Entrenamiento, 120) || Utilities.getUuid();
  const now = new Date();

  const sanitizedSeries = rows.map(row => {
    if (cleanText_(row.ID_EjercicioPlan, 120) !== exerciseId) {
      throw new Error('Todas las series deben pertenecer al mismo ejercicio.');
    }
    const numeroSerie = positiveInt_(row.NumeroSerie, 1, maxSeries, 'NumeroSerie');
    return {
      ID_RegistroSerie: requiredId_(row.ID_RegistroSerie, 'ID_RegistroSerie'),
      ID_EjercicioPlan: exerciseId,
      Fecha: parseDateOrToday_(row.Fecha),
      Timestamp: parseTimestampOrNow_(row.Timestamp, now),
      NumeroSerie: numeroSerie,
      Peso: boundedNumber_(row.Peso, 0, 1000, 'Peso'),
      RepsRealizadas: positiveInt_(row.RepsRealizadas, 0, 1000, 'RepsRealizadas'),
      RIRReal: boundedNumber_(row.RIRReal, 0, 10, 'RIRReal'),
      ComentarioSerie: cleanText_(row.ComentarioSerie, RIR_CONFIG.MAX_COMMENT_LENGTH),
      Completada: toBoolean_(row.Completada),
      ID_Entrenamiento: batchId,
      Usuario: email,
      NombreEjercicioReal: cleanText_(row.NombreEjercicioReal || exerciseRow.NombreEjercicioReal || plan.NombreEjercicio, 180),
      GrupoMuscularReal: cleanText_(row.GrupoMuscularReal || exerciseRow.GrupoMuscularReal || plan.GrupoMuscular, 80),
    };
  });

  const sanitizedExercise = {
    ID_RegistroEjercicio: requiredId_(exerciseRow.ID_RegistroEjercicio, 'ID_RegistroEjercicio'),
    ID_EjercicioPlan: exerciseId,
    Fecha: parseDateOrToday_(exerciseRow.Fecha),
    ComentarioGeneral: cleanText_(exerciseRow.ComentarioGeneral, RIR_CONFIG.MAX_COMMENT_LENGTH),
    EjercicioCompletado: toBoolean_(exerciseRow.EjercicioCompletado),
    ID_Entrenamiento: batchId,
    Timestamp: parseTimestampOrNow_(exerciseRow.Timestamp, now),
    Usuario: email,
    NombreEjercicioReal: cleanText_(exerciseRow.NombreEjercicioReal || plan.NombreEjercicio, 180),
    GrupoMuscularReal: cleanText_(exerciseRow.GrupoMuscularReal || plan.GrupoMuscular, 80),
  };

  const insertedSeries = appendUniqueObjects_(
    ss.getSheetByName('RegistroSeries'),
    sanitizedSeries,
    'ID_RegistroSerie'
  );
  const insertedExercise = appendUniqueObjects_(
    ss.getSheetByName('RegistroEjercicios'),
    [sanitizedExercise],
    'ID_RegistroEjercicio'
  );

  const sessionState = updateSessionStateForExercise_(ss, exerciseId);
  SpreadsheetApp.flush();

  return {
    ok: true,
    insertedSeries,
    insertedExercise,
    sessionState,
    idEntrenamiento: batchId,
  };
}

function saveLegacySeries_(ss, payload, email) {
  const rows = Array.isArray(payload.rows) ? payload.rows : [];
  if (!rows.length) return { ok: true, insertedSeries: 0 };

  const now = new Date();
  const sanitized = rows.map(row => {
    const exerciseId = cleanText_(row.ID_EjercicioPlan, 120);
    const plan = getExercisePlan_(ss, exerciseId);
    if (!plan) throw new Error('Ejercicio no encontrado: ' + exerciseId);
    return {
      ID_RegistroSerie: requiredId_(row.ID_RegistroSerie, 'ID_RegistroSerie'),
      ID_EjercicioPlan: exerciseId,
      Fecha: parseDateOrToday_(row.Fecha),
      Timestamp: parseTimestampOrNow_(row.Timestamp, now),
      NumeroSerie: positiveInt_(row.NumeroSerie, 1, 20, 'NumeroSerie'),
      Peso: boundedNumber_(row.Peso, 0, 1000, 'Peso'),
      RepsRealizadas: positiveInt_(row.RepsRealizadas, 0, 1000, 'RepsRealizadas'),
      RIRReal: boundedNumber_(row.RIRReal, 0, 10, 'RIRReal'),
      ComentarioSerie: cleanText_(row.ComentarioSerie, RIR_CONFIG.MAX_COMMENT_LENGTH),
      Completada: toBoolean_(row.Completada),
      ID_Entrenamiento: cleanText_(row.ID_Entrenamiento, 120),
      Usuario: email,
      NombreEjercicioReal: cleanText_(row.NombreEjercicioReal || plan.NombreEjercicio, 180),
      GrupoMuscularReal: cleanText_(row.GrupoMuscularReal || plan.GrupoMuscular, 80),
    };
  });

  return {
    ok: true,
    insertedSeries: appendUniqueObjects_(ss.getSheetByName('RegistroSeries'), sanitized, 'ID_RegistroSerie')
  };
}

function saveLegacyExercise_(ss, payload, email) {
  const row = payload.row || {};
  const exerciseId = cleanText_(row.ID_EjercicioPlan, 120);
  if (!getExercisePlan_(ss, exerciseId)) throw new Error('Ejercicio no encontrado: ' + exerciseId);

  const sanitized = {
    ID_RegistroEjercicio: requiredId_(row.ID_RegistroEjercicio, 'ID_RegistroEjercicio'),
    ID_EjercicioPlan: exerciseId,
    Fecha: parseDateOrToday_(row.Fecha),
    ComentarioGeneral: cleanText_(row.ComentarioGeneral, RIR_CONFIG.MAX_COMMENT_LENGTH),
    EjercicioCompletado: toBoolean_(row.EjercicioCompletado),
    ID_Entrenamiento: cleanText_(row.ID_Entrenamiento, 120),
    Timestamp: parseTimestampOrNow_(row.Timestamp, new Date()),
    Usuario: email,
    NombreEjercicioReal: cleanText_(row.NombreEjercicioReal || getExercisePlan_(ss, exerciseId).NombreEjercicio, 180),

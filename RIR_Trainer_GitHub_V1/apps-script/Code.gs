function doGet() {
  try {
    assertAuthorized_();
    const template = HtmlService.createTemplateFromFile('Index');
    template.appIconUrl = getAppIconUrl_();
    template.appUrl = ScriptApp.getService().getUrl() || '';
    return template
      .evaluate()
      .setTitle('RIR Trainer')
      .addMetaTag('viewport', 'width=device-width, initial-scale=1, viewport-fit=cover');
  } catch (error) {
    return HtmlService
      .createHtmlOutput(renderAccessError_(error))
      .setTitle('RIR Trainer — acceso denegado')
      .addMetaTag('viewport', 'width=device-width, initial-scale=1, viewport-fit=cover');
  }
}

/**
 * Ejecutar una vez manualmente desde Apps Script.
 * Configura la cuenta autorizada y amplía la estructura sin borrar datos.
 */
function setupRIRTrainer() {
  const ownerEmail = normalizeEmail_(
    Session.getActiveUser().getEmail() || Session.getEffectiveUser().getEmail()
  );
  if (!ownerEmail) {
    throw new Error('No se ha podido identificar la cuenta de Google que ejecuta la configuración.');
  }

  const props = PropertiesService.getScriptProperties();
  if (!props.getProperty(RIR_CONFIG.PROP_SPREADSHEET_ID)) {
    props.setProperty(RIR_CONFIG.PROP_SPREADSHEET_ID, RIR_CONFIG.DEFAULT_SPREADSHEET_ID);
  }
  if (!props.getProperty(RIR_CONFIG.PROP_ALLOWED_EMAILS)) {
    props.setProperty(RIR_CONFIG.PROP_ALLOWED_EMAILS, ownerEmail);
  }

  const ss = getSpreadsheet_();
  validateRequiredSheets_(ss);

  const appIcon = instalarIconoIPhone();
  const changes = [];
  changes.push(ensureHeaders_(ss, 'RegistroSeries', RIR_HEADERS.RegistroSeries));
  changes.push(ensureHeaders_(ss, 'RegistroEjercicios', RIR_HEADERS.RegistroEjercicios));
  changes.push(ensureHeaders_(ss, 'CalendarioActividades', RIR_HEADERS.CalendarioActividades));
  changes.push(ensureHeaders_(ss, 'RegistroEntrenamientos', RIR_HEADERS.RegistroEntrenamientos));
  changes.push(ensureHeaders_(ss, 'Calentamientos', RIR_HEADERS.Calentamientos));
  changes.push(ensureHeaders_(ss, 'RegistroCalentamientos', RIR_HEADERS.RegistroCalentamientos));
  changes.push(ensureHeaders_(ss, 'SustitucionesSesion', RIR_HEADERS.SustitucionesSesion));
  changes.push(ensureHeaders_(ss, 'MapaMuscular', RIR_HEADERS.MapaMuscular));
  changes.push(ensureHeaders_(ss, 'EjerciciosPlan', RIR_EXERCISE_EXTRA_HEADERS));
  const ladderProgression = setLadderProgressionV61_(ss);

  const seededWarmups = seedWarmups_(ss);
  const seededMuscleMap = seedMuscleMap_(ss);
  const migratedCalendar = migrateLegacyCalendar_(ss, ownerEmail);
  const mesocycleDates = syncCurrentMesocycleDates_(ss);
  const sessionUpdates = recalculateAllSessionStates_(ss);
  const diagnosis = diagnoseWorkbook_(ss);

  return {
    ok: true,
    spreadsheetId: ss.getId(),
    allowedEmails: getAllowedEmails_(),
    changes: changes.filter(Boolean),
    ladderProgression,
    seededWarmups,
    seededMuscleMap,
    migratedCalendar,
    mesocycleDates,
    sessionUpdates,
    diagnosis,
    appIcon,
  };
}

/**
 * Crea el PNG del icono en Google Drive, lo comparte como lector mediante enlace
 * y guarda una URL HTTPS que Safari puede utilizar al añadir la web a Inicio.
 * Ejecuta esta función una vez y vuelve a desplegar una nueva versión.
 */
function instalarIconoIPhone() {
  const props = PropertiesService.getScriptProperties();
  let file = null;
  const currentId = props.getProperty(RIR_CONFIG.PROP_APP_ICON_FILE_ID);

  if (currentId) {
    try {
      file = DriveApp.getFileById(currentId);
      if (file.isTrashed()) file = null;
    } catch (error) {
      file = null;
    }
  }

  if (!file) {
    const bytes = Utilities.base64Decode(RIR_APP_ICON_BASE64);
    const blob = Utilities.newBlob(bytes, 'image/png', 'RIR_Trainer_icon_180.png');
    file = DriveApp.createFile(blob);
  }

  try {
    if (file.getSecurityUpdateEligible()) file.setSecurityUpdateEnabled(false);
  } catch (error) {
    // Algunas cuentas no exponen esta opción; el enlace público sigue siendo válido.
  }

  file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);

  const version = String(Date.now());
  const iconUrl = 'https://drive.google.com/thumbnail?id=' + encodeURIComponent(file.getId()) +
    '&sz=w180&v=' + version;

  props.setProperties({
    [RIR_CONFIG.PROP_APP_ICON_FILE_ID]: file.getId(),
    [RIR_CONFIG.PROP_APP_ICON_URL]: iconUrl,
    [RIR_CONFIG.PROP_APP_ICON_VERSION]: version,
  }, false);

  return {
    ok: true,
    fileId: file.getId(),
    iconUrl,
    fileName: file.getName(),
  };
}

function getAppIconUrl_() {
  return PropertiesService.getScriptProperties().getProperty(RIR_CONFIG.PROP_APP_ICON_URL) || '';
}

/**
 * Permite cambiar la lista blanca desde el editor de Apps Script.
 * Ejemplo: setAllowedEmails(['cuenta@gmail.com']);
 */
function setAllowedEmails(emails) {
  const executor = normalizeEmail_(
    Session.getActiveUser().getEmail() || Session.getEffectiveUser().getEmail()
  );
  if (!executor) throw new Error('No se ha podido identificar al administrador del script.');

  const normalized = Array.from(new Set((emails || []).map(normalizeEmail_).filter(Boolean)));
  if (!normalized.length) throw new Error('Debe existir al menos una cuenta autorizada.');

  PropertiesService.getScriptProperties().setProperty(
    RIR_CONFIG.PROP_ALLOWED_EMAILS,
    normalized.join(',')
  );
  return { ok: true, allowedEmails: normalized };
}

function getBootstrapData() {
  const email = assertAuthorized_();
  const ss = getSpreadsheet_();
  validateRequiredSheets_(ss);
  const registroEjercicios = sheetToObjects_(ss, 'RegistroEjercicios')
    .filter(row => !String(row.ID_EjercicioPlan || '').startsWith('CAL-'));

function seedMuscleMap_(ss) {
  const sheet = ensureSheet_(ss, 'MapaMuscular', RIR_HEADERS.MapaMuscular);
  ensureHeaders_(ss, 'MapaMuscular', RIR_HEADERS.MapaMuscular);
  const existing = new Set(sheetToObjectsRaw_(ss, 'MapaMuscular').map(r => normalizeExerciseName_(r.NombreEjercicio)));
  const unique = new Map();
  sheetToObjectsRaw_(ss, 'EjerciciosPlan').forEach(e => {
    const name = String(e.NombreEjercicio || '').trim();
    const key = normalizeExerciseName_(name);
    if (name && key && !unique.has(key)) unique.set(key, { name, group: String(e.GrupoMuscular || 'Otro') });
  });
  const rows = [];
  unique.forEach(item => {
    const key = normalizeExerciseName_(item.name);
    if (existing.has(key)) return;
    const map = inferMuscleMapping_(item.name, item.group);
    rows.push({NombreEjercicio:item.name,MusculoPrincipal:map.primary,CoefPrincipal:1,MusculoSecundario1:map.secondary1||'',CoefSecundario1:map.coef1||'',MusculoSecundario2:map.secondary2||'',CoefSecundario2:map.coef2||''});
  });
  if (!rows.length) return 0;
  const headers = getHeaders_(sheet);
  sheet.getRange(sheet.getLastRow()+1,1,rows.length,headers.length).setValues(rows.map(r => headers.map(h => r[h] !== undefined ? r[h] : '')));
  return rows.length;
}

function inferMuscleMapping_(name, fallbackGroup) {
  const n = normalizeExerciseName_(name);
  const fallback = fallbackGroup || 'Otro';
  if (/sentadilla|bulgara|step down|zancada|prensa/.test(n)) return {primary:'Cuádriceps',secondary1:'Glúteo',coef1:0.5,secondary2:'Core',coef2:0.25};
  if (/peso muerto|rumano|curl femoral|isquio/.test(n)) return {primary:'Isquio',secondary1:'Glúteo',coef1:0.5,secondary2:'Espalda',coef2:0.25};
  if (/hip thrust|puente gluteo/.test(n)) return {primary:'Glúteo',secondary1:'Isquio',coef1:0.5,secondary2:'Core',coef2:0.25};
  if (/dominada|jalon|remo/.test(n)) return {primary:'Espalda',secondary1:'Bíceps',coef1:0.5,secondary2:'Hombro',coef2:0.25};
  if (/press banca|press mancuerna|press inclinado|flexion/.test(n)) return {primary:'Pecho',secondary1:'Tríceps',coef1:0.5,secondary2:'Hombro',coef2:0.5};
  if (/fondos/.test(n)) return {primary:fallback==='Tríceps'?'Tríceps':'Pecho',secondary1:fallback==='Tríceps'?'Pecho':'Tríceps',coef1:0.5,secondary2:'Hombro',coef2:0.25};
  if (/press militar|press hombro/.test(n)) return {primary:'Hombro',secondary1:'Tríceps',coef1:0.5,secondary2:'Core',coef2:0.25};
  if (/elevacion|face pull|remo alto/.test(n)) return {primary:'Hombro',secondary1:'Espalda',coef1:0.25};
  if (/curl|biceps/.test(n)) return {primary:'Bíceps'};
  if (/triceps|press frances/.test(n)) return {primary:'Tríceps'};
  if (/plancha|pallof|core|bird dog/.test(n)) return {primary:'Core'};
  return {primary:fallback};
}

function normalizeExerciseName_(value) {
  return String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, ' ').replace(/\s+/g, ' ').trim();
}

function getCalendarRows_(ss) {
  const sheet = ss.getSheetByName('CalendarioActividades');
  return sheet ? sheetToObjects_(ss, 'CalendarioActividades') : [];
}

function getExercisePlan_(ss, exerciseId) {
  if (!exerciseId) return null;
  return sheetToObjectsRaw_(ss, 'EjerciciosPlan')
    .find(row => String(row.ID_EjercicioPlan) === String(exerciseId)) || null;
}


function findObjectByColumns_(sheet, criteria) {
  if (!sheet || sheet.getLastRow() < 2) return null;
  const headers = getHeaders_(sheet);
  const keys = Object.keys(criteria || {});
  const indexes = keys.map(k => headers.indexOf(k));
  if (indexes.some(i => i < 0)) return null;
  const rows = sheet.getRange(2, 1, sheet.getLastRow() - 1, headers.length).getValues();
  const idx = rows.findIndex(row => keys.every((key, i) => String(row[indexes[i]]) === String(criteria[key])));
  if (idx < 0) return null;
  const object = {};
  headers.forEach((header, i) => { if (header) object[header] = rows[idx][i]; });
  object.__rowNumber = idx + 2;
  return object;
}

function upsertObjectByColumns_(sheet, object, keyHeaders, preserveHeaders) {
  if (!sheet) throw new Error('No existe la hoja de destino.');
  const headers = getHeaders_(sheet);
  const keys = keyHeaders || [];
  const keyIndexes = keys.map(k => headers.indexOf(k));
  if (keyIndexes.some(i => i < 0)) throw new Error('Faltan columnas clave en ' + sheet.getName() + '.');
  const rows = sheet.getLastRow() > 1
    ? sheet.getRange(2, 1, sheet.getLastRow() - 1, headers.length).getValues()
    : [];
  const index = rows.findIndex(row => keys.every((key, i) => String(row[keyIndexes[i]]) === String(object[key])));
  let merged = Object.assign({}, object);
  if (index >= 0) {
    const existing = {};
    headers.forEach((header, i) => { if (header) existing[header] = rows[index][i]; });
    merged = Object.assign({}, existing, object);
    (preserveHeaders || []).forEach(header => {
      if (existing[header] !== '' && existing[header] !== null && existing[header] !== undefined) {
        merged[header] = existing[header];
      }
    });
    const values = headers.map(header => merged[header] !== undefined ? merged[header] : '');
    sheet.getRange(index + 2, 1, 1, headers.length).setValues([values]);
    return { action: 'updated', object: merged, rowNumber: index + 2 };
  }
  const values = headers.map(header => merged[header] !== undefined ? merged[header] : '');
  sheet.getRange(sheet.getLastRow() + 1, 1, 1, headers.length).setValues([values]);
  return { action: 'inserted', object: merged, rowNumber: sheet.getLastRow() };
}

function appendUniqueObjects_(sheet, objects, idHeader) {
  if (!sheet) throw new Error('No existe la hoja de destino.');
  if (!objects.length) return 0;

  const headers = getHeaders_(sheet);
  const idCol = headers.indexOf(idHeader) + 1;
  if (idCol <= 0) throw new Error('Falta la columna ' + idHeader + ' en ' + sheet.getName() + '.');

  const existing = new Set(
    sheet.getLastRow() > 1
      ? sheet.getRange(2, idCol, sheet.getLastRow() - 1, 1).getValues().flat().map(String)
      : []
  );
  const unique = objects.filter(object => {
    const id = String(object[idHeader]);
    if (!id || existing.has(id)) return false;
    existing.add(id);
    return true;
  });
  if (!unique.length) return 0;

  const values = unique.map(object => headers.map(header => object[header] !== undefined ? object[header] : ''));
  sheet.getRange(sheet.getLastRow() + 1, 1, values.length, headers.length).setValues(values);
  return values.length;
}

function sheetToObjects_(ss, sheetName) {
  return sheetToObjectsRaw_(ss, sheetName).map(row => {
    const result = {};
    Object.keys(row).forEach(key => {
      result[key] = serializeCell_(key, row[key]);
    });
    return result;
  });
}

function sheetToObjectsRaw_(ss, sheetName) {
  const sheet = ss.getSheetByName(sheetName);
  if (!sheet || sheet.getLastRow() < 1 || sheet.getLastColumn() < 1) return [];
  const values = sheet.getDataRange().getValues();
  if (!values.length) return [];
  const headers = values.shift().map(value => String(value || '').trim());
  return values
    .filter(row => row.some(value => value !== '' && value !== null))
    .map(row => {
      const object = {};
      headers.forEach((header, index) => {
        if (header) object[header] = row[index];
      });
      return object;
    });
}

function serializeCell_(header, value) {
  if (!(value instanceof Date)) return value;
  if (/timestamp/i.test(header)) return serializeTimestamp_(value);
  return formatDateOnly_(value);
}

function ensureHeaders_(ss, sheetName, requiredHeaders) {
  const sheet = ensureSheet_(ss, sheetName, requiredHeaders);
  const headers = getHeaders_(sheet);
  const missing = requiredHeaders.filter(header => !headers.includes(header));
  if (!missing.length) return '';

  const startColumn = headers.length + 1;
  sheet.getRange(1, startColumn, 1, missing.length).setValues([missing]);
  sheet.getRange(1, 1, 1, headers.length + missing.length)
    .setFontWeight('bold')
    .setBackground('#1a1a1a')
    .setFontColor('#ffffff');
  return sheetName + ': añadidas ' + missing.join(', ');
}

function ensureSheet_(ss, sheetName, headers) {
  let sheet = ss.getSheetByName(sheetName);
  if (!sheet) {
    sheet = ss.insertSheet(sheetName);
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.setFrozenRows(1);
    sheet.getRange(1, 1, 1, headers.length)
      .setFontWeight('bold')
      .setBackground('#1a1a1a')
      .setFontColor('#ffffff');
  }
  return sheet;
}

function getHeaders_(sheet) {
  if (!sheet || sheet.getLastColumn() < 1) return [];
  return sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0]
    .map(value => String(value || '').trim());
}

function validateRequiredSheets_(ss) {
  const missing = RIR_REQUIRED_SHEETS.filter(name => !ss.getSheetByName(name));
  if (missing.length) throw new Error('Faltan hojas obligatorias: ' + missing.join(', '));
}

function getSpreadsheet_() {
  const id = PropertiesService.getScriptProperties().getProperty(RIR_CONFIG.PROP_SPREADSHEET_ID)
    || RIR_CONFIG.DEFAULT_SPREADSHEET_ID;
  return SpreadsheetApp.openById(id);
}

function assertAuthorized_() {
  const email = normalizeEmail_(Session.getActiveUser().getEmail());
  if (!email) {
    throw new Error(
      'Google no ha podido verificar tu identidad. Despliega la aplicación como “Usuario que accede a la aplicación web”.'
    );
  }

  const allowed = getAllowedEmails_();
  if (!allowed.length) {
    throw new Error('La aplicación aún no está configurada. Ejecuta setupRIRTrainer() desde Apps Script.');
  }
  if (!allowed.includes(email)) {
    throw new Error('La cuenta ' + email + ' no está autorizada para acceder a RIR Trainer.');
  }
  return email;
}

function getAllowedEmails_() {
  const value = PropertiesService.getScriptProperties().getProperty(RIR_CONFIG.PROP_ALLOWED_EMAILS) || '';
  return Array.from(new Set(value.split(/[;,\s]+/).map(normalizeEmail_).filter(Boolean)));
}

function normalizeEmail_(value) {
  return String(value || '').trim().toLowerCase();
}

function requiredId_(value, field) {
  const id = cleanText_(value, 160);
  if (!id || !/^[A-Za-z0-9._:-]+$/.test(id)) throw new Error(field + ' no es válido.');
  return id;
}

function cleanText_(value, maxLength) {
  return String(value === null || value === undefined ? '' : value)
    .replace(/[\u0000-\u0008\u000B\u000C\u000E-\u001F]/g, '')
    .trim()
    .slice(0, maxLength || 500);
}

function normalizeNumber_(value) {
  if (typeof value === 'number') return value;
  const parsed = Number(String(value || '').replace(',', '.'));
  return Number.isFinite(parsed) ? parsed : NaN;
}

function boundedNumber_(value, min, max, field) {
  const number = normalizeNumber_(value);
  if (!Number.isFinite(number) || number < min || number > max) {
    throw new Error(field + ' debe estar entre ' + min + ' y ' + max + '.');
  }
  return number;
}

function toOptionalNumber_(value) {
  if (value === '' || value === null || value === undefined) return null;
  const number = normalizeNumber_(value);
  return Number.isFinite(number) ? number : null;
}

function positiveInt_(value, min, max, field) {
  const number = Number.parseInt(String(value), 10);
  if (!Number.isInteger(number) || number < min || number > max) {
    throw new Error(field + ' debe estar entre ' + min + ' y ' + max + '.');
  }
  return number;
}

function toBoolean_(value) {
  return value === true || String(value).toUpperCase() === 'TRUE' || value === 1 || value === '1';
}

function parseDateOrToday_(value) {
  const parsed = parseDate_(value);
  const date = parsed || new Date();
  return new Date(date.getFullYear(), date.getMonth(), date.getDate());
}

function parseTimestampOrNow_(value, fallback) {
  if (value instanceof Date && !isNaN(value.getTime())) return value;
  const parsed = new Date(value);
  return isNaN(parsed.getTime()) ? (fallback || new Date()) : parsed;
}

function parseDate_(value) {
  if (value instanceof Date && !isNaN(value.getTime())) return value;
  if (typeof value === 'number' && Number.isFinite(value)) {
    return new Date(Math.round((value - 25569) * 86400 * 1000));
  }
  const raw = String(value || '').trim();
  if (!raw) return null;

  let match = raw.match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
  if (match) return new Date(Number(match[1]), Number(match[2]) - 1, Number(match[3]));

  match = raw.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
  if (match) {
    let year = Number(match[3]);
    if (year < 100) year += 2000;
    return new Date(year, Number(match[2]) - 1, Number(match[1]));
  }

  const parsed = new Date(raw);
  return isNaN(parsed.getTime()) ? null : parsed;
}

function normalizeDateKey_(value) {
  const date = parseDate_(value);
  if (!date) return '';
  return Utilities.formatDate(date, RIR_CONFIG.TIME_ZONE, 'yyyy-MM-dd');
}

function formatDateOnly_(value) {
  const date = parseDate_(value);
  if (!date) return value === null || value === undefined ? '' : String(value);
  return Utilities.formatDate(date, RIR_CONFIG.TIME_ZONE, 'dd/MM/yyyy');
}

function serializeTimestamp_(value) {
  const date = parseTimestampOrNow_(value, new Date(0));
  return Utilities.formatDate(date, RIR_CONFIG.TIME_ZONE, "yyyy-MM-dd'T'HH:mm:ssXXX");
}

function dedupeRowsById_(rows, field) {
  const seen = new Set();
  return rows.filter(row => {
    const id = String(row[field] || '');
    if (!id || seen.has(id)) return false;
    seen.add(id);
    return true;
  });
}

function countLogicalDuplicates_(rows, keyFn) {
  const counts = new Map();
  rows.forEach(row => {
    const key = keyFn(row);
    counts.set(key, (counts.get(key) || 0) + 1);
  });
  let duplicates = 0;
  counts.forEach(count => { if (count > 1) duplicates += count - 1; });
  return duplicates;
}

function renderAccessError_(error) {
  const message = escapeHtml_(error && error.message ? error.message : String(error));
  return `<!doctype html>
  <html lang="es"><head><meta charset="utf-8">
  <style>
    body{margin:0;background:#0d0d0d;color:#f0f0f0;font-family:-apple-system,BlinkMacSystemFont,sans-serif;display:grid;place-items:center;min-height:100vh;padding:24px;box-sizing:border-box}
    main{max-width:520px;background:#1a1a1a;border:1px solid #2e2e2e;border-radius:18px;padding:24px}
    h1{font-size:23px;margin:0 0 12px;color:#f5a623}p{line-height:1.55;color:#bbb}code{color:#fff}
  </style></head><body><main><h1>Acceso protegido</h1><p>${message}</p>
  <p>Abre la aplicación con la cuenta de Google autorizada. Si es la primera instalación, ejecuta <code>setupRIRTrainer()</code> desde el editor de Apps Script.</p></main></body></html>`;
}

function escapeHtml_(value) {
  return String(value || '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;')
    .replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
}


// ── V5: calendario lógico sin duplicados ──
function calendarLogicalKey_(row) {
  const dateKey = normalizeDateKey_(row.Fecha);
  const category = String(row.Categoria || '').toLowerCase();
  const type = String(row.Tipo || '').toUpperCase();
  if (category === 'fuerza') return 'fuerza|' + dateKey + '|' + (String(row.ID_Sesion || '') || type);
  if (category === 'descanso') return 'descanso|' + dateKey;
  return 'id|' + String(row.ID_Actividad || '');
}
function calendarRowScore_(row) {
  let score = 0;
  const timestamp = parseDate_(row.Timestamp);
  if (timestamp) score += timestamp.getTime();
  if (String(row.Estado || '').toLowerCase() === 'hecho') score += 1e15;
  if (row.ID_Entrenamiento) score += 1e14;
  if (row.ID_Sesion) score += 1e13;
  return score;
}
function dedupeCalendarActivities_(rows) {
  const map = new Map();
  (rows || []).forEach(row => {
    const key = calendarLogicalKey_(row);
    const current = map.get(key);
    if (!current || calendarRowScore_(row) >= calendarRowScore_(current)) map.set(key, row);
  });
  return Array.from(map.values());
}

/**
 * Opcional: crea una copia de seguridad y marca como eliminadas las actividades
 * de fuerza/descanso históricas que sean duplicados lógicos.
 */
function limpiarDuplicadosCalendarioV5() {
  assertAuthorized_();
  const ss = getSpreadsheet_();
  const sheet = ss.getSheetByName('CalendarioActividades');
  if (!sheet || sheet.getLastRow() < 3) return {ok:true, marked:0};
  const backupName = makeBackupName_('CalendarioActividades');
  sheet.copyTo(ss).setName(backupName);
  const headers = getHeaders_(sheet);
  const values = sheet.getRange(2,1,sheet.getLastRow()-1,headers.length).getValues();
  const stateIndex = headers.indexOf('Estado');
  const tsIndex = headers.indexOf('Timestamp');
  const objects = values.map((row,i) => {
    const object = {}; headers.forEach((h,j)=>object[h]=row[j]); object.__index=i; return object;
  }).filter(r => String(r.Estado || 'hecho').toLowerCase() !== 'eliminado');
  const groups = new Map();
  objects.forEach(r => {
    const category = String(r.Categoria || '').toLowerCase();
    if (!['fuerza','descanso'].includes(category)) return;
    const key = calendarLogicalKey_(r);
    if (!groups.has(key)) groups.set(key, []);
    groups.get(key).push(r);
  });
  let marked = 0;
  groups.forEach(rows => {
    if (rows.length < 2) return;
    rows.sort((a,b)=>calendarRowScore_(b)-calendarRowScore_(a));
    rows.slice(1).forEach(r => {
      values[r.__index][stateIndex] = 'eliminado';
      if (tsIndex >= 0) values[r.__index][tsIndex] = new Date();
      marked++;
    });
  });
  if (marked) sheet.getRange(2,1,values.length,headers.length).setValues(values);
  return {ok:true, marked, backupSheet:backupName};
}


/** V7 — auditoría de sincronización de una sesión concreta. */
function getSyncAuditV7_(ss, payload, email) {
  const workoutId = requiredId_(payload.ID_Entrenamiento, 'ID_Entrenamiento');
  const rows = sheetToObjectsRaw_(ss, 'RegistroSeries').filter(r => String(r.ID_Entrenamiento) === workoutId);
  const completed = rows.filter(r => toBoolean_(r.Completada));
  const logical = new Map();
  completed.forEach(r => {
    const key = String(r.ID_EjercicioPlan) + '|S' + String(Number(r.NumeroSerie) || 0);
    if (!logical.has(key)) logical.set(key, []);
    logical.get(key).push(r);
  });
  const summary = sheetToObjectsRaw_(ss, 'RegistroEntrenamientos')
    .find(r => String(r.ID_Entrenamiento) === workoutId) || null;
  return {
    ok: true,
    workoutId,
    user: email,
    physicalRows: rows.length,
    completedRows: completed.length,
    uniqueCompletedSeries: logical.size,
    logicalDuplicates: Array.from(logical.values()).reduce((sum, group) => sum + Math.max(0, group.length - 1), 0),
    workoutStatus: summary ? String(summary.Estado || '') : '',
    lastModified: summary ? serializeTimestamp_(summary.FechaModificacion || summary.HoraFin || '') : '',
  };
}

/**
 * V7 — limpieza segura de duplicados lógicos de series.
 * Conserva la fila con mayor RevisionCliente y, a igualdad, la más reciente.
 * Crea una copia de seguridad antes de modificar.
 */
function repararDuplicadosLogicosSeriesV7() {
  assertAuthorized_();
  const ss = getSpreadsheet_();
  const sheet = ss.getSheetByName('RegistroSeries');
  if (!sheet || sheet.getLastRow() < 2) return { ok:true, marked:0 };
  ensureHeaders_(ss, 'RegistroSeries', RIR_HEADERS.RegistroSeries);
  const backupName = makeBackupName_('RegistroSeries_V7');
  sheet.copyTo(ss).setName(backupName);
  const headers = getHeaders_(sheet);
  const data = sheet.getRange(2,1,sheet.getLastRow()-1,headers.length).getValues();
  const idx = Object.fromEntries(headers.map((h,i)=>[h,i]));
  const groups = new Map();
  data.forEach((row,rowIndex)=>{
    const workout=String(row[idx.ID_Entrenamiento]||'');
    const exercise=String(row[idx.ID_EjercicioPlan]||'');
    const number=String(Number(row[idx.NumeroSerie])||0);
    if(!workout||!exercise||number==='0')return;
    const key=workout+'|'+exercise+'|'+number;
    if(!groups.has(key))groups.set(key,[]);
    groups.get(key).push({row,rowIndex});
  });
  const deleteIndexes=[];
  groups.forEach(items=>{
    if(items.length<2)return;
    items.sort((a,b)=>{
      const revA=Number(a.row[idx.RevisionCliente])||0,revB=Number(b.row[idx.RevisionCliente])||0;
      if(revA!==revB)return revB-revA;
      return parseTimestampOrNow_(b.row[idx.FechaModificacion]||b.row[idx.Timestamp],new Date(0))-
             parseTimestampOrNow_(a.row[idx.FechaModificacion]||a.row[idx.Timestamp],new Date(0));
    });
    items.slice(1).forEach(x=>deleteIndexes.push(x.rowIndex+2));
  });
  deleteIndexes.sort((a,b)=>b-a).forEach(row=>sheet.deleteRow(row));
  return {ok:true,deleted:deleteIndexes.length,backupSheet:backupName};
}

/* ========================================================================== 
 * RIR Trainer 8 — API nativa para Capacitor
 * --------------------------------------------------------------------------
 * Esta API convive con la aplicación web protegida por Google. Para el iPhone
 * nativo se crea una SEGUNDA implementación de Apps Script:
 *   - Ejecutar como: yo (propietario)
 *   - Acceso: cualquier usuario con el enlace
 * La URL queda protegida por un token aleatorio cuyo hash vive en Properties.
 * El token se genera con setupNativeApi() y solo se muestra una vez.
 * ========================================================================== */
const RIR_NATIVE_API_CONFIG = Object.freeze({
  PROP_TOKEN_HASH: 'RIR_NATIVE_API_TOKEN_HASH',
  PROP_EMAIL: 'RIR_NATIVE_API_EMAIL',
  PROP_CREATED_AT: 'RIR_NATIVE_API_CREATED_AT',
  MAX_BODY_LENGTH: 250000,
});

/**
 * Ejecuta manualmente una vez. Devuelve el token en texto claro para pegarlo
 * en Ajustes de la app. Apps Script solo conserva su hash SHA-256.
 */
function setupNativeApi() {
  const email = normalizeEmail_(
    Session.getActiveUser().getEmail() || Session.getEffectiveUser().getEmail()
  );
  if (!email) throw new Error('No se ha podido identificar la cuenta propietaria.');
  const token = [Utilities.getUuid(), Utilities.getUuid(), Date.now().toString(36)]
    .join('-').replace(/=/g, '');
  const props = PropertiesService.getScriptProperties();
  props.setProperties({
    [RIR_NATIVE_API_CONFIG.PROP_TOKEN_HASH]: hashNativeToken_(token),
    [RIR_NATIVE_API_CONFIG.PROP_EMAIL]: email,
    [RIR_NATIVE_API_CONFIG.PROP_CREATED_AT]: new Date().toISOString(),
  });
  return {
    ok: true,
    apiUrl: ScriptApp.getService().getUrl() || '',
    token,
    email,
    warning: 'Copia el token ahora. No se podrá volver a consultar; solo rotarlo.',
  };
}

/** Rota el token y revoca inmediatamente el anterior. */
function rotateNativeApiToken() {
  return setupNativeApi();
}

/** Diagnóstico sin revelar el token. */
function getNativeApiStatus() {
  assertAuthorized_();
  const props = PropertiesService.getScriptProperties();
  return {
    ok: true,
    configured: Boolean(props.getProperty(RIR_NATIVE_API_CONFIG.PROP_TOKEN_HASH)),
    email: props.getProperty(RIR_NATIVE_API_CONFIG.PROP_EMAIL) || '',
    createdAt: props.getProperty(RIR_NATIVE_API_CONFIG.PROP_CREATED_AT) || '',
    deploymentUrl: ScriptApp.getService().getUrl() || '',
  };
}

/** Endpoint JSON usado por CapacitorHttp. */
function doPost(e) {
  try {
    const raw = String(e && e.postData && e.postData.contents || '');
    if (!raw || raw.length > RIR_NATIVE_API_CONFIG.MAX_BODY_LENGTH) {
      throw new Error('Petición vacía o demasiado grande.');
    }
    const request = JSON.parse(raw);
    const email = assertNativeToken_(request.token);
    const action = String(request.action || '');

    if (action === 'ping') {
      return nativeJsonOutput_({ ok: true, data: { pong: true, serverTime: new Date().toISOString() } });
    }
    if (action === 'bootstrap') {
      return nativeJsonOutput_({ ok: true, data: getBootstrapDataNative_(email) });
    }
    if (action === 'write') {
      const result = apiWriteNative_(request.payload, email);
      return nativeJsonOutput_({ ok: true, result });
    }
    throw new Error('Acción de API no permitida.');
  } catch (error) {
    return nativeJsonOutput_({
      ok: false,
      message: error && error.message ? error.message : String(error),
    });
  }
}

function getBootstrapDataNative_(email) {
  const ss = getSpreadsheet_();
  validateRequiredSheets_(ss);
  const registroEjercicios = sheetToObjects_(ss, 'RegistroEjercicios')
    .filter(row => !String(row.ID_EjercicioPlan || '').startsWith('CAL-'));
  const calendarioActividades = dedupeCalendarActivities_(getCalendarRows_(ss)
    .filter(row => String(row.Estado || 'hecho').toLowerCase() !== 'eliminado'));
  const workoutSheet = ss.getSheetByName('RegistroEntrenamientos');
  return {
    ok: true,
    user: { email },
    serverTime: new Date().toISOString(),
    config: sheetToObjects_(ss, 'Configuracion'),
    sesiones: sheetToObjects_(ss, 'Sesiones'),
    ejercicios: sheetToObjects_(ss, 'EjerciciosPlan'),
    registroSeries: dedupeRowsById_(sheetToObjects_(ss, 'RegistroSeries'), 'ID_RegistroSerie'),
    registroEjercicios: dedupeRowsById_(registroEjercicios, 'ID_RegistroEjercicio'),
    registroEntrenamientos: workoutSheet
      ? dedupeRowsById_(sheetToObjects_(ss, 'RegistroEntrenamientos'), 'ID_Entrenamiento')
      : [],
    calendarioActividades,
    calentamientos: sheetToObjects_(ss, 'Calentamientos'),
    registroCalentamientos: dedupeRowsById_(
      sheetToObjects_(ss, 'RegistroCalentamientos'), 'ID_RegistroCalentamiento'
    ),
    sustituciones: sheetToObjects_(ss, 'SustitucionesSesion')
      .filter(row => String(row.Estado || 'activo').toLowerCase() !== 'eliminado'),
    mapaMuscular: sheetToObjects_(ss, 'MapaMuscular'),
    medidas: sheetToObjects_(ss, 'Medidas'),
  };
}

function apiWriteNative_(payload, email) {
  if (!payload || typeof payload !== 'object') throw new Error('Petición de escritura inválida.');
  const lock = LockService.getScriptLock();
  if (!lock.tryLock(15000)) throw new Error('La hoja está ocupada. Vuelve a intentarlo.');
  try {
    const ss = getSpreadsheet_();
    const type = String(payload.type || '');
    switch (type) {
      case 'exerciseBatch': return saveExerciseBatch_(ss, payload, email);
      case 'seriesUpsert': return saveSeriesUpsert_(ss, payload, email);
      case 'workoutStart': return saveWorkoutStart_(ss, payload, email);
      case 'calendar': return saveCalendarActivity_(ss, payload, email);
      case 'calendarDelete': return deleteCalendarActivity_(ss, payload, email);
      case 'finishWorkout': return saveWorkoutSummary_(ss, payload, email);
      case 'warmupBatch': return saveWarmupBatch_(ss, payload, email);
      case 'substitution': return saveSubstitution_(ss, payload, email);
      case 'substitutionDelete': return deleteSubstitution_(ss, payload, email);
      case 'measures': return saveMeasures_(ss, payload, email);
      case 'syncAudit': return getSyncAuditV7_(ss, payload, email);
      default: throw new Error('Tipo de operación no permitido: ' + type);
    }
  } finally {
    lock.releaseLock();
  }
}

function assertNativeToken_(token) {
  const supplied = String(token || '');
  if (supplied.length < 40) throw new Error('Token de dispositivo ausente o inválido.');
  const props = PropertiesService.getScriptProperties();
  const expected = props.getProperty(RIR_NATIVE_API_CONFIG.PROP_TOKEN_HASH) || '';
  if (!expected || hashNativeToken_(supplied) !== expected) {
    throw new Error('Token de dispositivo no autorizado.');
  }
  return props.getProperty(RIR_NATIVE_API_CONFIG.PROP_EMAIL) || 'native-device';
}

function hashNativeToken_(token) {
  const digest = Utilities.computeDigest(
    Utilities.DigestAlgorithm.SHA_256,
    String(token),
    Utilities.Charset.UTF_8
  );
  return digest.map(byte => ('0' + ((byte + 256) % 256).toString(16)).slice(-2)).join('');
}

function nativeJsonOutput_(value) {
  return ContentService
    .createTextOutput(JSON.stringify(value))
    .setMimeType(ContentService.MimeType.JSON);
}
